---
export interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: Record<string, unknown>;
  noindex?: boolean;
}
const { title, description, canonical, schema, noindex } = Astro.props;
const siteUrl = 'https://dryliningedinburgh.co.uk';
const canonicalUrl = canonical ? `${siteUrl}${canonical}` : siteUrl;
const pageTitle = title.includes('Drylining Edinburgh') ? title : `${title} | Drylining Edinburgh`;

const globalOrgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Drylining Edinburgh",
  "url": "https://dryliningedinburgh.co.uk",
  "@id": "https://dryliningedinburgh.co.uk/#business",
  "sameAs": [
    "https://www.wikidata.org/entity/Q23436",
    "https://en.wikipedia.org/wiki/Edinburgh",
    "https://www.wikidata.org/entity/Q385378"
  ],
  "knowsAbout": [
    "https://en.wikipedia.org/wiki/Drywall",
    "https://en.wikipedia.org/wiki/Plaster",
    "https://en.wikipedia.org/wiki/Partition_wall",
    "https://en.wikipedia.org/wiki/Building_regulations_in_the_United_Kingdom",
    "https://en.wikipedia.org/wiki/Construction_worker",
    "https://en.wikipedia.org/wiki/General_contractor",
    "https://en.wikipedia.org/wiki/Cold-formed_steel",
    "https://en.wikipedia.org/wiki/Dropped_ceiling"
  ],
  "areaServed": {
    "@type": "Place",
    "name": "Edinburgh",
    "sameAs": [
      "https://en.wikipedia.org/wiki/Edinburgh",
      "https://www.wikidata.org/entity/Q23436"
    ]
  }
};
---
<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  {noindex && <meta name="robots" content="noindex" />}
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#C41E3A" />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Drylining Edinburgh" />
  <meta property="og:image" content={`${siteUrl}/images/hero-main.jpg`} />
  <meta property="og:locale" content="en_GB" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`${siteUrl}/images/hero-main.jpg`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-0C6E28VESS"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-0C6E28VESS');
  </script>
  <script type="application/ld+json" set:html={JSON.stringify(globalOrgSchema)} />
  {schema && (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  )}
  <style is:global>
    :root {
      --primary: #C41E3A;
      --primary-dark: #9E1830;
      --primary-light: rgba(196,30,58,0.1);
      --secondary: #111111;
      --accent: #F5F5F5;
      --white: #FFFFFF;
      --text: #333333;
      --text-light: #666666;
      --border: #E5E5E5;
      --radius: 8px;
      --shadow: 0 4px 20px rgba(0,0,0,0.08);
      --shadow-lg: 0 10px 40px rgba(0,0,0,0.12);
      --max-width: 1200px;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: 'Inter', system-ui, -apple-system, sans-serif; color: var(--text); line-height: 1.6; background: var(--white); }
    a { color: inherit; text-decoration: none; }
    img { max-width: 100%; display: block; }
    .container { width: 100%; max-width: var(--max-width); margin: 0 auto; padding: 0 1.5rem; }
    .section { padding: 5rem 0; }
    .section-title { font-size: 2.25rem; font-weight: 800; color: var(--secondary); margin-bottom: 1rem; line-height: 1.2; }
    .section-subtitle { font-size: 1.125rem; color: var(--text-light); margin-bottom: 3rem; max-width: 700px; }
    .btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 2rem; border-radius: var(--radius); font-weight: 600; font-size: 1rem; transition: all 0.2s ease; border: none; cursor: pointer; }
    .btn-primary { background: var(--primary); color: var(--white); }
    .btn-primary:hover { background: var(--primary-dark); transform: translateY(-2px); box-shadow: var(--shadow-lg); }
    .btn-secondary { background: var(--secondary); color: var(--white); }
    .btn-secondary:hover { background: #000; transform: translateY(-2px); }
    .btn-outline { background: transparent; color: var(--primary); border: 2px solid var(--primary); }
    .btn-outline:hover { background: var(--primary); color: var(--white); }
    .btn-white { background: var(--white); color: var(--primary); }
    .btn-white:hover { background: var(--accent); }
    @media (max-width: 768px) {
      .section { padding: 3rem 0; }
      .section-title { font-size: 1.75rem; }
      .hero-grid {
        grid-template-columns: 1fr !important;
        gap: 1.5rem !important;
        padding: 2rem 1.5rem !important;
      }
      .desktop-nav {
        display: none !important;
      }
    }
    .nav-dropdown:hover .dropdown-menu,
    .nav-dropdown:focus-within .dropdown-menu { display: block !important; }
    .dropdown-menu a:hover { background: rgba(196,30,58,0.05); }
  </style>
</head>
<body>
  <header style="background: var(--white); border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 100;">
    <div class="container" style="display: flex; align-items: center; justify-content: space-between; height: 72px;">
      <a href="/" style="display: flex; align-items: center; gap: 0.5rem; font-weight: 800; font-size: 1.5rem; color: var(--secondary);">
        <span style="color: var(--primary);">Drylining</span> Edinburgh
      </a>
      <nav style="display: flex; gap: 1.25rem; align-items: center;" class="desktop-nav">
        <a href="/services/" style="font-weight: 500; font-size: 0.8125rem; color: var(--text);">Services</a>
        <a href="/areas/" style="font-weight: 500; font-size: 0.8125rem; color: var(--text);">Areas</a>
        <div class="nav-dropdown" style="position: relative;">
          <a href="/about/" style="font-weight: 500; font-size: 0.8125rem; color: var(--text);">About</a>
          <div class="dropdown-menu" style="display: none; position: absolute; top: 100%; left: 0; background: var(--white); border: 1px solid var(--border); border-radius: var(--radius); padding: 6px 0; min-width: 140px; box-shadow: var(--shadow); z-index: 200;">
            <a href="/about/" style="display: block; padding: 6px 14px; font-size: 0.8125rem; font-weight: 500; color: var(--text);">About Us</a>
            <a href="/faq/" style="display: block; padding: 6px 14px; font-size: 0.8125rem; color: var(--text-light);">FAQ</a>
          </div>
        </div>
        <a href="/resources/dry-lining-cost-guide/" style="font-weight: 500; font-size: 0.8125rem; color: var(--text);">Resources</a>
        <a href="/contact/" style="font-weight: 500; font-size: 0.8125rem; color: var(--text);">Contact</a>
        <div style="display: flex; gap: 0.5rem; align-items: center; flex-shrink: 0;">
          <a href="tel:08008203090" class="btn btn-secondary" style="padding: 0.5rem 1rem; font-size: 0.75rem; white-space: nowrap;">FREEPHONE: 0800 820 3090</a>
          <a href="/get-quote/" class="btn btn-primary" style="padding: 0.5rem 1rem; font-size: 0.75rem; white-space: nowrap;">Contact Us</a>
        </div>
      </nav>
      <button id="mobileMenuBtn" style="display: none; background: none; border: none; font-size: 1.5rem; cursor: pointer;" aria-label="Open menu">☰</button>
    </div>
    <nav id="mobileNav" style="display: none; border-top: 1px solid var(--border); padding: 1rem 1.5rem; flex-direction: column; gap: 1rem; background: var(--white);">
      <a href="/services/" style="font-weight: 500; color: var(--text); padding: 0.5rem 0;">Services</a>
      <a href="/areas/" style="font-weight: 500; color: var(--text); padding: 0.5rem 0;">Areas</a>
      <a href="/about/" style="font-weight: 500; color: var(--text); padding: 0.5rem 0;">About</a>
      <a href="/faq/" style="font-weight: 500; color: var(--text-light); padding: 0.5rem 0 0.5rem 1.25rem; font-size: 0.9375rem;">— FAQ</a>
      <a href="/resources/dry-lining-cost-guide/" style="font-weight: 500; color: var(--text); padding: 0.5rem 0;">Resources</a>
      <a href="/contact/" style="font-weight: 500; color: var(--text); padding: 0.5rem 0;">Contact</a>
      <a href="tel:08008203090" class="btn btn-secondary" style="text-align: center;">FREEPHONE: 0800 820 3090</a>
      <a href="/get-quote/" class="btn btn-primary" style="text-align: center;">Contact Us</a>
    </nav>
  </header>
  <main>
    <slot />
  </main>
  <footer style="background: var(--secondary); color: var(--white); padding: 4rem 0 2rem;">
    <div class="container">
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 3rem; margin-bottom: 3rem;">
        <div>
          <div style="font-weight: 800; font-size: 1.5rem; margin-bottom: 1rem;"><span style="color: var(--primary);">Drylining</span> Edinburgh</div>
          <p style="color: #aaa; font-size: 0.9375rem; line-height: 1.7;">Professional drylining and partition wall contractors serving Edinburgh, Leith, Livingston, Falkirk, Dalkeith, and Musselburgh. CSCS-accredited, fully insured, free quotes.</p>
        </div>
        <div>
          <h4 style="font-weight: 700; margin-bottom: 1rem; font-size: 1rem; text-transform: uppercase; letter-spacing: 0.05em;">Services</h4>
          <ul style="list-style: none; display: flex; flex-direction: column; gap: 0.5rem;">
            <li><a href="/services/drylining-contractors/" style="color: #aaa; font-size: 0.9375rem;">Drylining Contractors</a></li>
            <li><a href="/services/partition-walls/" style="color: #aaa; font-size: 0.9375rem;">Partition Walls</a></li>
            <li><a href="/services/suspended-ceilings/" style="color: #aaa; font-size: 0.9375rem;">Suspended Ceilings</a></li>
            <li><a href="/services/plasterboard-installation/" style="color: #aaa; font-size: 0.9375rem;">Plasterboard Installation</a></li>
          </ul>
        </div>
        <div>
          <h4 style="font-weight: 700; margin-bottom: 1rem; font-size: 1rem; text-transform: uppercase; letter-spacing: 0.05em;">Areas</h4>
          <ul style="list-style: none; display: flex; flex-direction: column; gap: 0.5rem;">
            <li><a href="/areas/edinburgh/" style="color: #aaa; font-size: 0.9375rem;">Edinburgh</a></li>
            <li><a href="/areas/leith/" style="color: #aaa; font-size: 0.9375rem;">Leith</a></li>
            <li><a href="/areas/livingston/" style="color: #aaa; font-size: 0.9375rem;">Livingston</a></li>
            <li><a href="/areas/falkirk/" style="color: #aaa; font-size: 0.9375rem;">Falkirk</a></li>
          </ul>
        </div>
        <div>
          <h4 style="font-weight: 700; margin-bottom: 1rem; font-size: 1rem; text-transform: uppercase; letter-spacing: 0.05em;">Contact</h4>
          <ul style="list-style: none; display: flex; flex-direction: column; gap: 0.5rem; color: #aaa; font-size: 0.9375rem;">
            <li>📞 <a href="tel:08008203090" style="color: #aaa;">FREEPHONE: 0800 820 3090</a></li>
            <li><a href="/get-quote/" class="btn btn-primary" style="margin-top: 0.5rem; display: inline-block;">Get a Free Quote</a></li>
          </ul>
        </div>
      </div>
      <div style="border-top: 1px solid #333; padding-top: 2rem; display: flex; flex-wrap: wrap; gap: 1rem; justify-content: space-between; align-items: center;">
        <p style="color: #888; font-size: 0.875rem;">© {new Date().getFullYear()} Drylining Edinburgh. All rights reserved.</p>
        <div style="display: flex; gap: 1.5rem; font-size: 0.875rem;">
          <a href="/about/" style="color: #888;">About</a>
          <a href="/contact/" style="color: #888;">Contact</a>
          <a href="/faq/" style="color: #888;">FAQ</a>
          <a href="/privacy/" style="color: #888;">Privacy</a>
        </div>
      </div>
    </div>
  </footer>
  <script>
    (function() {
      var btn = document.getElementById('mobileMenuBtn');
      var nav = document.getElementById('mobileNav');
      if (!btn || !nav) return;
      function update() {
        var isMobile = window.innerWidth < 768;
        btn.style.display = isMobile ? 'block' : 'none';
        if (!isMobile) nav.style.display = 'none';
      }
      update();
      window.addEventListener('resize', update);
      btn.addEventListener('click', function() {
        nav.style.display = nav.style.display === 'flex' ? 'none' : 'flex';
      });
    })();
  </script>
</body>
</html>
