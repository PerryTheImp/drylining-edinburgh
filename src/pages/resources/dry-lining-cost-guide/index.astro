---
import Layout from '../../../layouts/Layout.astro';

/* ── Data ─────────────────────────────────────────────────────────── */

const residentialCosts = [
  { service: 'Standard plasterboard walls (tape & joint finish)', cost: '£26 – £47' },
  { service: 'Dry lining / dot and dab to blockwork', cost: '£23 – £40' },
  { service: 'Plasterboard ceilings (standard)', cost: '£29 – £50' },
  { service: 'Moisture-resistant or fire-rated board upgrade', cost: 'Add £4 – £8 per m²' },
  { service: 'Full skim coat over plasterboard', cost: 'Add £6 – £10 per m²' },
  { service: 'Insulated plasterboard (thermal upgrade)', cost: '£36 – £58 per m²' },
  { service: 'Acoustic dry lining (soundproofing)', cost: '£42 – £68 per m²' },
];

const commercialCosts = [
  { service: 'Standard plasterboard walls (tape & joint finish)', cost: '£23 – £42' },
  { service: 'Dry lining / dot and dab to blockwork', cost: '£21 – £36' },
  { service: 'Plasterboard ceilings (standard)', cost: '£26 – £47' },
  { service: 'Moisture-resistant or fire-rated board upgrade', cost: 'Add £3 – £7 per m²' },
  { service: 'Full skim coat over plasterboard', cost: 'Add £5 – £9 per m²' },
  { service: 'Insulated plasterboard (thermal upgrade)', cost: '£33 – £52 per m²' },
  { service: 'Acoustic dry lining (soundproofing)', cost: '£40 – £63 per m²' },
];

const serviceCosts = [
  { service: 'Plastering (skim coat over sound plaster)', cost: '£21 – £37 per m²' },
  { service: 'Plastering (full two-coat re-plaster)', cost: '£29 – £47 per m²' },
  { service: 'Partition wall (standard, per linear metre)', cost: '£42 – £85 per m' },
  { service: 'Metal stud partitioning (single-layer)', cost: '£52 – £95 per m' },
  { service: 'Metal stud partitioning (double-layer acoustic/fire)', cost: '£73 – £125 per m' },
  { service: 'Suspended ceiling (flat plasterboard)', cost: '£31 – £57 per m²' },
  { service: 'MF ceiling (metal frame + plasterboard)', cost: '£26 – £47 per m²' },
  { service: 'Rendering (sand and cement)', cost: '£42 – £68 per m²' },
  { service: 'Rendering (silicone / monocouche)', cost: '£85 – £128 per m²' },
  { service: 'Insulation (PIR-backed plasterboard)', cost: '£16 – £31 per m²' },
  { service: 'Tape and jointing (standard walls)', cost: '£6 – £10 per m²' },
  { service: 'Dot and dab (standard board)', cost: '£21 – £36 per m²' },
  { service: 'Dot and dab (insulated board)', cost: '£29 – £47 per m²' },
  { service: 'Floor screeding (traditional sand & cement)', cost: '£19 – £29 per m²' },
];

const timeframes = [
  { project: 'Single room dry lining', duration: '1 – 2 days', costRange: '£550 – £1,300' },
  { project: 'Whole house dry lining (3–4 bed)', duration: '1 – 2 weeks', costRange: '£3,700 – £8,000' },
  { project: 'Commercial office fit-out (500–1,000 m²)', duration: '2 – 4 weeks', costRange: '£16,000 – £42,000' },
  { project: 'New build dry lining (residential)', duration: '3 – 6 weeks', costRange: '£8,500 – £21,000' },
  { project: 'Small flat dry lining', duration: '2 – 4 days', costRange: '£1,600 – £3,200' },
  { project: 'Large detached house (5+ bed)', duration: '2 – 3 weeks', costRange: '£7,500 – £16,000' },
];

const factors = [
  { factor: 'Property type', description: 'New builds are faster and cheaper per m² than renovations. Edinburgh\'s Georgian and Victorian properties may need specialist lime-based prep work or traditional wet plaster compatibility before dry lining can begin.' },
  { factor: 'Access difficulty', description: 'Tight staircases in tenement buildings, no lift access, high ceilings over 2.4 m, or restricted parking in Edinburgh city centre all add labour time. A top-floor flat in Leith or New Town with no lift can push labour up by £180 – £350.' },
  { factor: 'Finish level', description: 'Level 3 (tape & joint, paint-ready) is standard. Level 4 (decorator-ready skim) and Level 5 (premium, defect-free) add progressively more labour and materials.' },
  { factor: 'Insulation requirements', description: 'PIR-backed insulated plasterboard, cavity fill, or mineral wool between studs adds material cost but improves thermal performance and EPC ratings. Essential for older Edinburgh properties with solid stone walls.' },
  { factor: 'Soundproofing needs', description: 'Acoustic partitions, resilient bars, and dense mineral wool are required between dwellings in tenement buildings and for home cinemas. Adds 30% – 50% to standard costs.' },
  { factor: 'Fire rating requirements', description: 'Building Regulations Part B (Scotland) mandates fire-rated board on escape routes, between garages and living spaces, and in commercial partitions. Fire-rated upgrades add £4 – £8 per m².' },
  { factor: 'Ceiling height', description: 'Ceilings over 2.4 m require longer boards, additional fixing, and possibly scaffolding or platforms. Each extra metre of height typically adds 10% – 15% to labour.' },
  { factor: 'Waste removal needs', description: 'Stripping old plaster, removing existing boards, or clearing packaging requires skip hire (£220 – £420 in Edinburgh) or disposal fees. Always confirm if included in your quote.' },
];

const compliance = [
  { item: 'Public liability insurance', requirement: '£1M minimum', note: 'Covers accidental damage to property or injury to third parties during works.' },
  { item: 'Employer liability insurance', requirement: '£10M', note: 'Legally required if the contractor employs staff. Covers injury to employees on site.' },
  { item: 'Professional indemnity insurance', requirement: '£500K – £1M (if applicable)', note: 'Relevant for design-and-build or specification-led work where errors could cause financial loss.' },
  { item: 'CSCS registration', requirement: 'Required for all site operatives', note: 'Construction Skills Certification Scheme proves training and competence. Ask for card numbers.' },
  { item: 'Building Regulation Part L (thermal)', requirement: 'Mandatory for new builds and extensions', note: 'Sets U-value targets for walls, floors, and roofs. Insulated dry lining often used to meet targets.' },
  { item: 'Building Regulation Part B (fire safety)', requirement: 'Mandatory for escape routes and compartments', note: 'Fire-rated boards, intumescent seals, and compartmentation must comply.' },
  { item: 'Building Regulation Part E (acoustics)', requirement: 'Mandatory between dwellings', note: 'Airborne and impact sound insulation standards for separating walls and floors.' },
];

const paymentTerms = [
  { term: 'Initial deposit', detail: 'Typically 25% – 50% of total project cost. Covers materials and initial labour. Never pay 100% upfront.' },
  { term: 'Milestone payments', detail: 'For larger projects, payments tied to completion stages (e.g., 25% on framing, 25% on boarding, 25% on finishing).' },
  { term: 'Final payment', detail: 'Balance due on practical completion, after snagging and client sign-off.' },
  { term: 'Retention', detail: '5% – 10% held back for a defects period (typically 3 – 12 months). Released once any defects are rectified.' },
  { term: 'Accepted payment methods', detail: 'Bank transfer (preferred), cheque, or card. Cash payments without receipt are not recommended.' },
];

const warnings = [
  { warning: 'Hidden access equipment costs', detail: 'Scaffolding, tower platforms, or cherry pickers for high ceilings or exteriors can add £550 – £2,800 in Edinburgh city centre. Always ask if included.' },
  { warning: 'Cowboy builder red flags', detail: 'No written quote, no business address, pressure to pay cash upfront, no insurance proof, unusually low prices, unwilling to provide references.' },
  { warning: 'Importance of written quotes', detail: 'A proper quote lists board type, thickness, finish level, waste removal, and what is excluded. Verbal estimates are not binding.' },
  { warning: 'Checklist for hiring a dry liner', detail: 'Check CSCS cards, request insurance certificates, ask for 2–3 recent references, confirm waste removal is included, clarify finish level, and agree payment terms in writing.' },
  { warning: 'Warranty and guarantee terms', detail: 'Reputable contractors offer 5–10 year guarantees on workmanship. Materials carry manufacturer warranties (typically 10–25 years). Get this in writing.' },
];

const faqs = [
  {
    q: 'How much does dry lining cost per square metre in Edinburgh?',
    a: 'Residential dry lining in Edinburgh typically costs £26 to £47 per m² for standard plasterboard walls with tape and joint finish. Ceilings run £29 to £50 per m². Commercial rates are slightly lower at £23 to £42 per m² due to economies of scale. Edinburgh sits slightly above the UK national average due to higher demand in the city and the Lothians.',
  },
  {
    q: 'Is dry lining cheaper than traditional plastering in Edinburgh?',
    a: 'Yes, dry lining is generally cheaper and much faster than traditional wet plastering. A standard room can be dry lined in 1–2 days versus 2–3 days for wet plaster. Dry lining also eliminates drying time, so decoration can start immediately. However, wet plaster provides a harder, more durable surface and is often preferred in Edinburgh\'s historic Georgian and Victorian properties where traditional finishes are required.',
  },
  {
    q: 'What is included in a proper dry lining quote in Edinburgh?',
    a: 'A comprehensive quote should specify board type and thickness (e.g., British Gypsum Gyproc Wallboard 12.5mm), fixing method (dot and dab or timber/metal frame), tape and jointing or skim finish, waste removal, insulation or fire-stopping if required, and estimated duration. Always ask for a written, itemised breakdown.',
  },
  {
    q: 'How do metal stud partitioning costs work in Edinburgh?',
    a: 'Metal stud partitions are priced per linear metre installed. A standard single-layer partition runs £52 to £95 per linear metre in Edinburgh. Acoustic or fire-rated upgrades, doors, and glazing sections are priced separately. Double-layer partitions with sound insulation run £73 to £125 per linear metre.',
  },
  {
    q: 'Do I need fire-rated plasterboard in my Edinburgh property?',
    a: 'Building Regulations Part B (Scotland) require fire-rated plasterboard (pink board, typically 12.5mm or 15mm) on escape routes, between garages and living spaces, in loft conversions, and in certain commercial partitions. A qualified contractor will advise what is required for your specific project.',
  },
  {
    q: 'How long does a typical dry lining project take in Edinburgh?',
    a: 'A single room takes 1–2 days. A small flat takes 2–4 days. A full 3-bedroom house takes 1–2 weeks. A commercial office fit-out of 500–1,000 m² takes 2–4 weeks. New build residential dry lining takes 3–6 weeks depending on property size and complexity.',
  },
  {
    q: 'What drives the price up on a dry lining job in Edinburgh?',
    a: 'Specialist boards (fire, acoustic, moisture-resistant), high ceilings in tenement properties, difficult access in the city centre, stripping old finishes, premium skim coat finishes (Level 4 or 5), and tight deadlines all add cost. The clearer your scope, the tighter and more accurate your quote will be.',
  },
  {
    q: 'What is the difference between Level 3, Level 4, and Level 5 finish?',
    a: 'Level 3 is tape and jointed, ready for textured paint. Level 4 is skimmed or fully jointed, ready for flat emulsion. Level 5 is a premium, defect-free finish for gloss paint or critical lighting conditions. Each level adds approximately £4–£8 per m² in Edinburgh.',
  },
  {
    q: 'Should I pay a deposit for dry lining work in Edinburgh?',
    a: 'A deposit of 25% to 50% is standard and reasonable. It covers materials and initial labour. Never pay 100% upfront. Ensure payment terms are documented in writing, including milestone payments for larger projects and retention for defects.',
  },
  {
    q: 'How do Edinburgh dry lining costs compare to the national average?',
    a: 'Edinburgh typically sits slightly above the UK national average for dry lining and plastering labour. Material costs are fairly uniform nationwide, but labour day rates in Edinburgh (£190–£260) are higher than the national average (£180–£250) due to demand and the city\'s cost of living.',
  },
  {
    q: 'What insurance should a dry lining contractor in Edinburgh have?',
    a: 'As a minimum, contractors should hold £1M public liability insurance and £10M employer liability insurance. For design-and-build projects, professional indemnity insurance of £500K to £1M is also advisable. Always request certificates.',
  },
  {
    q: 'Can dry lining improve my Edinburgh property\'s energy efficiency?',
    a: 'Yes. Insulated plasterboard (PIR-backed) can significantly improve wall U-values and help meet Part L building regulations. Internal solid wall insulation via dry lining is a cost-effective way to reduce heat loss in older Edinburgh properties with solid stone walls.',
  },
  {
    q: 'What is dot and dab dry lining?',
    a: 'Dot and dab is a method where plasterboard is fixed directly to masonry walls using dabs of adhesive. It is quicker than timber framing, provides a small cavity for services, and is ideal where walls are reasonably flat. Typical cost in Edinburgh: £21–£36 per m².',
  },
  {
    q: 'Do I need building regulations approval for dry lining in Edinburgh?',
    a: 'Not for simple dry lining in existing rooms. However, dry lining in loft conversions, extensions, or where thermal/fire/acoustic upgrades are made may require Edinburgh City Council or the relevant Lothian council building control sign-off. A competent contractor will advise when approval is needed.',
  },
  {
    q: 'What brands of plasterboard do professional dry liners use in Edinburgh?',
    a: 'The leading UK manufacturers are British Gypsum (Gyproc range), Knauf, and Lafarge (part of Saint-Gobain). Each offers standard, moisture-resistant, fire-rated, acoustic, and thermal boards. Reputable contractors will specify the brand and board type in their quote.',
  },
];

