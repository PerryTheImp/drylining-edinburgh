---
import Layout from '../layouts/Layout.astro';
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "ContactPage",
      "name": "Contact Drylining Edinburgh",
      "url": "https://dryliningedinburgh.co.uk/contact/"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://dryliningedinburgh.co.uk/" },
        { "@type": "ListItem", "position": 2, "name": "Contact", "item": "https://dryliningedinburgh.co.uk/contact/" }
      ]
    }
  ]
};
---
<Layout title="Contact Us | Drylining Edinburgh - Get in Touch" description="Contact Drylining Edinburgh for drylining, partition walls, and suspended ceiling services. Call, email, or fill out our quote form for a free consultation." canonical="/contact/" schema={schema}>
<section style="position:relative;min-height:400px;display:flex;align-items:center;background:linear-gradient(135deg,#1a1a2e 0%,#16213e 100%);overflow:hidden;">
  <img src="/images/contact-office.jpg" alt="Drylining Edinburgh contact centre" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.25;">
  <div class="container" style="position:relative;z-index:1;text-align:center;">
    <h1 style="font-size:2.5rem;font-weight:800;color:var(--white);margin-bottom:1rem;">Contact Drylining Edinburgh</h1>
    <p style="font-size:1.0625rem;color:rgba(255,255,255,0.85);max-width:700px;margin:0 auto;">Have a question or ready to start your project? We are here to help. Reach out by phone, email, or use our quick quote form.</p>
  </div>
</section>
<section class="section"><div class="container"><div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:2rem;max-width:900px;margin:0 auto;">
<div style="background:var(--accent);padding:2rem;border-radius:var(--radius);">
<div style="font-size:2rem;margin-bottom:1rem;">📞</div>
<h3 style="font-size:1.25rem;font-weight:700;color:var(--secondary);margin-bottom:0.5rem;">Phone</h3>
<p style="color:var(--text-light);font-size:0.9375rem;margin-bottom:1rem;">Speak directly with our team for urgent enquiries or to book a site visit.</p>
<a href="tel:08008203090" style="color:var(--primary);font-weight:600;font-size:1.0625rem;">FREEPHONE 0800 820 3090</a>
</div>
<div style="background:var(--accent);padding:2rem;border-radius:var(--radius);">
<div style="font-size:2rem;margin-bottom:1rem;">📝</div>
<h3 style="font-size:1.25rem;font-weight:700;color:var(--secondary);margin-bottom:0.5rem;">Request a Quote</h3>
<p style="color:var(--text-light);font-size:0.9375rem;margin-bottom:1rem;">Get a free, no-obligation quote. Fast response guaranteed.</p>
<form action="https://script.google.com/macros/s/AKfycbx2ROgDcHu3ArLmfqPETQYCkFn_5YP6fy1WfZMbynAZsoARpnMRntm5iLlgKSFSJBkG/exec" method="POST" id="contactQuoteForm" style="display:flex;flex-direction:column;gap:0.75rem;">
<input type="hidden" name="source" value="dryliningedinburgh-co-uk-contact" />
<input type="text" name="name" required placeholder="Your name" style="width:100%;padding:0.75rem 0.875rem;border:1px solid var(--border);border-radius:var(--radius);font-size:0.875rem;font-family:inherit;" />
<input type="tel" name="phone" required placeholder="Phone number" style="width:100%;padding:0.75rem 0.875rem;border:1px solid var(--border);border-radius:var(--radius);font-size:0.875rem;font-family:inherit;" />
<input type="email" name="email" placeholder="Email (optional)" style="width:100%;padding:0.75rem 0.875rem;border:1px solid var(--border);border-radius:var(--radius);font-size:0.875rem;font-family:inherit;" />
<textarea name="details" rows="3" placeholder="Tell us about your project..." style="width:100%;padding:0.75rem 0.875rem;border:1px solid var(--border);border-radius:var(--radius);font-size:0.875rem;font-family:inherit;resize:vertical;"></textarea>
<button type="submit" class="btn btn-primary" id="contactSubmitBtn" style="width:100%;">Request Free Quote</button>
<div id="contactFormMessage" style="padding:0.75rem;border-radius:var(--radius);display:none;font-size:0.875rem;"></div>
</form>
</div>
</div></div></section>
<section class="section" style="background:var(--accent);"><div class="container" style="text-align:center;max-width:700px;">
<h2 style="font-size:1.75rem;font-weight:700;color:var(--secondary);margin-bottom:1rem;">Working Hours</h2>
<p style="color:var(--text-light);font-size:1.0625rem;line-height:1.8;">We are available Monday to Friday, 8:00 AM to 6:00 PM. For commercial projects, we also offer evening and weekend appointments to minimise business disruption.</p>
</div></section>

<!-- Map -->
<section style="padding: 0 0 4rem;">
  <div class="container">
    <h2 style="font-size: 1.75rem; font-weight: 800; margin-bottom: 1.5rem; text-align: center;">Our Service Area</h2>
    <div style="border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow);">
      <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d71555.62850068595!2d-3.277093606242918!3d55.91273422774955!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4887b800a5982623%3A0x64f2147b7ce71727!2sEdinburgh!5e0!3m2!1sen!2suk!4v1783435240184!5m2!1sen!2suk" width="100%" height="450" style="border:0; display:block;" allowfullscreen="" loading="lazy" referrerpolicy="strict-origin-when-cross-origin"></iframe>
    </div>
  </div>
</section>
<script>
(function(){
var form=document.getElementById('contactQuoteForm');var btn=document.getElementById('contactSubmitBtn');var msg=document.getElementById('contactFormMessage');if(!form)return;
form.addEventListener('submit',function(e){
e.preventDefault();
btn.disabled=true;btn.textContent='Sending...';msg.style.display='none';
var data=new FormData(form);var payload={};
data.forEach(function(v,k){payload[k]=v;});
fetch(form.action,{method:'POST',body:JSON.stringify(payload),headers:{'Content-Type':'application/json'},mode:'no-cors'})
.then(function(r){if(r.ok||r.status===0){msg.style.display='block';msg.style.background='#dcfce7';msg.style.color='#15803d';msg.style.border='1px solid #bbf7d0';msg.textContent='Thank you! We will contact you within 24 hours.';form.reset();}else{throw new Error('Status '+r.status);}})
.catch(function(){msg.style.display='block';msg.style.background='#fee2e2';msg.style.color='#b91c1c';msg.style.border='1px solid #fecaca';msg.textContent='Something went wrong. Please call us on 0800 820 3090 or try again.';})
.finally(function(){btn.disabled=false;btn.textContent='Request Free Quote';});
});
})();
</script>
</Layout>
