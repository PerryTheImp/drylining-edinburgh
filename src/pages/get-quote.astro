---
import Layout from '../layouts/Layout.astro';
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "serviceType": "Drylining Quote Request",
      "provider": { "@type": "LocalBusiness", "name": "Drylining Edinburgh", "@id": "https://dryliningedinburgh.co.uk/#business" },
      "areaServed": { "@type": "City", "name": "Edinburgh" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://dryliningedinburgh.co.uk/" },
        { "@type": "ListItem", "position": 2, "name": "Get a Quote", "item": "https://dryliningedinburgh.co.uk/get-quote/" }
      ]
    }
  ]
};
---
<Layout title="Get a Free Quote | Drylining Edinburgh" description="Request a free, no-obligation quote for drylining, partition walls, and suspended ceilings in Edinburgh. Fast response within 24 hours." canonical="/get-quote/" schema={schema}>
<section style="position:relative;min-height:400px;display:flex;align-items:center;background:linear-gradient(135deg,#1a1a2e 0%,#16213e 100%);overflow:hidden;">
  <img src="/images/hero-main.jpg" alt="Edinburgh renovation project ready for drylining quote" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.25;">
  <div class="container" style="position:relative;z-index:1;text-align:center;">
    <h1 style="font-size:2.5rem;font-weight:800;color:var(--white);margin-bottom:1rem;">Get Your Free Quote</h1>
    <p style="font-size:1.0625rem;color:rgba(255,255,255,0.85);max-width:700px;margin:0 auto;">Tell us about your project and we will provide a free, no-obligation quote within 24 hours. No hidden fees, no pressure.</p>
  </div>
</section>
<section class="section"><div class="container"><div style="max-width:600px;margin:0 auto;background:var(--white);padding:2.5rem;border-radius:var(--radius);box-shadow:var(--shadow);">
  <div style="max-width:600px;margin:0 auto;background:var(--white);padding:2.5rem;border-radius:var(--radius);box-shadow:var(--shadow);">
    <form action="https://script.google.com/macros/s/AKfycbxB8ovk-ohPp_hzhkmHSOPVut_33L6mT5eSjtstmLuDx9laqcBk3qwv3GG7Lcyk9IB1/exec" method="POST" id="quoteForm" style="display:flex;flex-direction:column;gap:1rem;">
      <input type="hidden" name="source" value="dryliningedinburgh.co.uk" />
      <input type="hidden" name="sheet" value="Edinburgh" />
      <input type="hidden" name="city" value="Edinburgh" />
      <input type="text" name="name" placeholder="Your name" required style="padding:0.75rem 1rem;border:1px solid var(--border);border-radius:var(--radius);font-size:0.9375rem;font-family:inherit;" />
      <input type="tel" name="phone" placeholder="Phone number" required style="padding:0.75rem 1rem;border:1px solid var(--border);border-radius:var(--radius);font-size:0.9375rem;font-family:inherit;" />
      <input type="email" name="email" placeholder="Email address" style="padding:0.75rem 1rem;border:1px solid var(--border);border-radius:var(--radius);font-size:0.9375rem;font-family:inherit;" />
      <input type="text" name="postcode" placeholder="Postcode" required style="padding:0.75rem 1rem;border:1px solid var(--border);border-radius:var(--radius);font-size:0.9375rem;font-family:inherit;" />
      <select name="service" required style="padding:0.75rem 1rem;border:1px solid var(--border);border-radius:var(--radius);font-size:0.9375rem;font-family:inherit;background:var(--white);color:var(--text);">
        <option value="" disabled selected>Select a service</option>
        <option>Drylining Contractors</option>
        <option>Partition Walls</option>
        <option>Metal Stud Partitioning</option>
        <option>Suspended Ceilings</option>
        <option>Plasterboard Installation</option>
        <option>Taping & Jointing</option>
        <option>Commercial Drylining</option>
        <option>Office Drylining</option>
      </select>
      <textarea name="details" placeholder="Project details (optional)" rows="3" style="padding:0.75rem 1rem;border:1px solid var(--border);border-radius:var(--radius);font-size:0.9375rem;font-family:inherit;resize:vertical;"></textarea>
      <button type="submit" class="btn btn-primary" id="quoteSubmitBtn" style="width:100%;margin-top:0.25rem;">Request Free Quote</button>
      <div id="quoteFormMessage" style="font-size:0.875rem;margin-top:0.5rem;display:none;"></div>
    </form>

    <script>
      (function() {
        var form = document.getElementById('quoteForm');
        var btn = document.getElementById('quoteSubmitBtn');
        var msg = document.getElementById('quoteFormMessage');
        if (!form) return;
        form.addEventListener('submit', function(e) {
          e.preventDefault();
          if (btn) { btn.disabled = true; btn.textContent = 'Sending...'; }
          if (msg) { msg.style.display = 'none'; }
          var data = new FormData(form);
          var payload = {};
          data.forEach(function(v, k) { payload[k] = v; });
          fetch(form.action, {
            method: 'POST',
            body: JSON.stringify(payload),
            headers: { 'Content-Type': 'application/json' }
          }).then(function(r) {
            if (r.ok || r.status === 0) {
              if (msg) { msg.style.display = 'block'; msg.style.color = '#15803d'; msg.textContent = 'Thank you! We will be in touch within 24 hours.'; }
              form.reset();
            } else {
              throw new Error('Status ' + r.status);
            }
          }).catch(function(err) {
            if (msg) { msg.style.display = 'block'; msg.style.color = '#c41e3a'; msg.textContent = 'Something went wrong. Please call us or try again.'; }
          }).finally(function() {
            if (btn) { btn.disabled = false; btn.textContent = 'Request Free Quote'; }
          });
        });
      })();
    </script>
  </div></div></section>
</Layout>
