---
export const prerender = true;

import Layout from "../layouts/Layout.astro";

const title = "Page Not Found | Drylining Edinburgh";
const description = "Sorry, the page you're looking for doesn't exist. Visit Drylining Edinburgh for professional drylining and partition wall services.";
---

<Layout title={title} description={description}>
  <div class="container" style="padding: 6rem 1.5rem; text-align: center; max-width: 600px; margin: 0 auto;">
    <div style="font-size: 6rem; margin-bottom: 1rem;">🔨</div>
    <h1 class="section-title" style="font-size: 3rem; margin-bottom: 1rem;">Page Not Found</h1>
    <p style="font-size: 1.125rem; color: var(--text-light); margin-bottom: 2rem;">
      Sorry, we couldn't find the page you're looking for. It might have been moved or doesn't exist.
    </p>
    <div style="display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; margin-bottom: 3rem;">
      <a href="/" class="btn btn-primary">🏠 Back to Home</a>
      <a href="/services/" class="btn btn-outline">Our Services</a>
      <a href="/contact/" class="btn btn-outline">Contact Us</a>
    </div>
    <div style="background: var(--accent); border-radius: var(--radius); padding: 2rem; text-align: left;">
      <h3 style="font-weight: 700; margin-bottom: 1rem; color: var(--secondary);">Popular Pages</h3>
      <ul style="list-style: none; display: flex; flex-direction: column; gap: 0.75rem;">
        <li><a href="/services/drylining-contractors/" style="color: var(--primary); font-weight: 500;">→ Drylining Contractors</a></li>
        <li><a href="/services/partition-walls/" style="color: var(--primary); font-weight: 500;">→ Partition Walls</a></li>
        <li><a href="/services/suspended-ceilings/" style="color: var(--primary); font-weight: 500;">→ Suspended Ceilings</a></li>
        <li><a href="/areas/edinburgh/" style="color: var(--primary); font-weight: 500;">→ Edinburgh Area</a></li>
        <li><a href="/get-quote/" style="color: var(--primary); font-weight: 500;">→ Get a Free Quote</a></li>
      </ul>
    </div>
  </div>
</Layout>
