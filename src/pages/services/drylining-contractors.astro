---
import Layout from '../../layouts/Layout.astro';

const serviceName = 'Drylining Contractors';
const serviceSlug = 'drylining-contractors';

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {"@type":"Question","name":"What is drylining?","acceptedAnswer":{"@type":"Answer","text":"Drylining is the process of fixing plasterboard to interior walls and ceilings without using wet plaster. It is faster, cleaner, and provides a smooth finish ready for decorating or painting."}},
    {"@type":"Question","name":"How long does drylining take?","acceptedAnswer":{"@type":"Answer","text":"A typical room takes 1-2 days depending on size and complexity. Whole-property drylining can take 1-2 weeks. We will give you a clear timeline during your quote."}},
    {"@type":"Question","name":"Is drylining cheaper than traditional plastering?","acceptedAnswer":{"@type":"Answer","text":"Drylining is generally more cost-effective than wet plastering for large areas. It requires less drying time, less labour, and produces minimal mess."}},
    {"@type":"Question","name":"Can drylining include insulation?","acceptedAnswer":{"@type":"Answer","text":"Yes. We install insulation-backed plasterboard to improve thermal performance and meet Part L building regulations."}},
    {"@type":"Question","name":"Do you provide a guarantee?","acceptedAnswer":{"@type":"Answer","text":"Yes. All our drylining work comes with a 12-month workmanship guarantee. We also use manufacturer-guaranteed materials from British Gypsum and Knauf."}},
    {"@type":"Question","name":"Is drylining suitable for bathrooms?","acceptedAnswer":{"@type":"Answer","text":"Yes, when moisture-resistant plasterboard is used. We also recommend appropriate tanking in high-moisture areas."}},
    {"@type":"Question","name":"What areas do you cover?","acceptedAnswer":{"@type":"Answer","text":"We provide drylining services across Edinburgh, Leith, Livingston, Dalkeith, Musselburgh, Falkirk, and all surrounding Lothians and Central Scotland areas."}}
  ],
};

const serviceJsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Drylining Contractors Edinburgh",
  additionalType: "https://www.wikidata.org/entity/Q213825",
  sameAs: "https://en.wikipedia.org/wiki/Drywall",
  provider: {
    "@type": "Organization",
    name: "Drylining Edinburgh",
    "@id": "https://dryliningedinburgh.co.uk/#business",
    knowsAbout: ['https://en.wikipedia.org/wiki/Drywall', 'https://en.wikipedia.org/wiki/Plaster', 'https://en.wikipedia.org/wiki/Partition_wall', 'https://en.wikipedia.org/wiki/Building_regulations_in_the_United_Kingdom', 'https://en.wikipedia.org/wiki/Construction_worker', 'https://en.wikipedia.org/wiki/General_contractor', 'https://en.wikipedia.org/wiki/Cold-formed_steel', 'https://en.wikipedia.org/wiki/Dropped_ceiling'],
  },
  areaServed: {
    "@type": "Place",
    name: "Edinburgh and surrounding areas",
    sameAs: [
      "https://en.wikipedia.org/wiki/Edinburgh",
      "https://www.wikidata.org/entity/Q23436"
    ],
  },
};
---

<Layout title="Drylining Contractors Edinburgh | Expert Installation & Finishing" description="Professional drylining contractors in Edinburgh. Residential & commercial drylining, plasterboard installation, taping & jointing. Free quotes. CSCS accredited." canonical="/services/drylining-contractors/">

<script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
<script type="application/ld+json" set:html={JSON.stringify(serviceJsonLd)} />

<!-- Hero -->
<section style="position:relative;min-height:400px;display:flex;align-items:center;background:linear-gradient(135deg,#1a1a2e 0%,#16213e 100%);overflow:hidden;border-radius:0 0 14px 14px;">
  <img src="/images/service-drylining.jpg" alt="Drylining contractors working on a construction site in Edinburgh" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.25;">
  <div class="container" style="position:relative;z-index:1;text-align:center;padding:60px 20px;">
    <nav style="font-size:13px;color:rgba(255,255,255,0.70);margin-bottom:12px;">
      <a href="/" style="text-decoration:none;color:rgba(255,255,255,0.70);">Home</a> / <a href="/services/" style="text-decoration:none;color:rgba(255,255,255,0.70);">Services</a> / <span style="color:#ffffff;">Drylining Contractors</span>
    </nav>
    <h1 style="font-size:clamp(28px,4vw,44px);font-weight:800;color:#ffffff;margin-bottom:14px;line-height:1.15;">Expert Drylining Contractors in Edinburgh</h1>
