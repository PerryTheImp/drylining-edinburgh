---
import Layout from '../../layouts/Layout.astro';
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "serviceType": "Plasterboard Installation",
      "provider": { "@type": "LocalBusiness", "name": "Drylining Edinburgh", "@id": "https://dryliningedinburgh.co.uk/#business" },
      "areaServed": { "@type": "City", "name": "Edinburgh" },
      "description": "Precision plasterboard installation in Edinburgh. Expert fitting for walls and ceilings. Moisture-resistant, fire-rated, and acoustic options."
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://dryliningedinburgh.co.uk/" },
        { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://dryliningedinburgh.co.uk/services/" },
        { "@type": "ListItem", "position": 3, "name": "Plasterboard Installation", "item": "https://dryliningedinburgh.co.uk/services/plasterboard-installation/" }
      ]
    }
  ]
};
---
<Layout title="Plasterboard Installation Edinburgh | Walls & Ceilings" description="Professional plasterboard installation in Edinburgh. Precision fitting for walls and ceilings. Moisture-resistant, fire-rated, and acoustic boards. Free quotes." canonical="/services/plasterboard-installation/" schema={schema}>
<section style="position:relative;min-height:400px;display:flex;align-items:center;background:linear-gradient(135deg,#1a1a2e 0%,#16213e 100%);overflow:hidden;">
  <img src="/images/service-plasterboard.svg" alt="Plasterboard installation in Edinburgh" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.25;">
  <div class="container" style="position:relative;z-index:1;text-align:center;">
    <h1 style="font-size:2.5rem;font-weight:800;color:var(--white);margin-bottom:1rem;">Plasterboard Installation in Edinburgh</h1>
    <p style="font-size:1.0625rem;color:rgba(255,255,255,0.85);max-width:700px;margin:0 auto;">Precision plasterboard fitting for walls and ceilings. Seamless joints, professional finishing, and minimal disruption to your project timeline.</p>
  </div>
</section>
<section class="section"><div class="container" style="max-width:900px;">
<p style="font-size:1.0625rem;color:var(--text);line-height:1.8;margin-bottom:1.5rem;">Plasterboard is the foundation of modern drylining. At <strong>Drylining Edinburgh</strong>, we provide expert plasterboard installation for walls, ceilings, and feature structures across Edinburgh and the Lothians. Our team ensures every board is cut precisely, fixed securely, and finished to a professional standard.</p>
<img src="/images/service-plasterboard.svg" alt="Professional plasterboard fitting in Edinburgh property" style="border-radius:var(--radius);width:100%;max-width:800px;margin:2rem auto;display:block;box-shadow:var(--shadow-lg);">
<h2 style="font-size:1.75rem;font-weight:700;color:var(--secondary);margin:2.5rem 0 1rem;">Types of Plasterboard We Install</h2>
<ul style="list-style:disc;padding-left:1.5rem;color:var(--text);line-height:1.8;font-size:1.0625rem;"><li><strong>Standard wallboard</strong> — For general walls and ceilings in dry areas</li><li><strong>Moisture-resistant board</strong> — For bathrooms, kitchens, and utility areas</li><li><strong>Fire-rated board</strong> — Where building regulations require fire resistance</li><li><strong>Acoustic board</strong> — For sound insulation between rooms and offices</li><li><strong>Thermal board</strong> — Pre-insulated for improved energy efficiency</li></ul>
<h2 style="font-size:1.75rem;font-weight:700;color:var(--secondary);margin:2.5rem 0 1rem;">Our Installation Process</h2>
<p style="font-size:1.0625rem;color:var(--text);line-height:1.8;margin-bottom:1.5rem;">We measure every surface accurately, cut boards to fit around sockets, pipes, and fixtures, and fix them securely to studs or direct-to-brick using the appropriate method. Our team works cleanly and efficiently, minimising dust and disruption to your property.</p>
<div style="margin-top:2.5rem;text-align:center;"><a href="/get-quote/" class="btn btn-primary" style="font-size:1.0625rem;padding:1rem 2.5rem;">Get a Free Plasterboard Quote</a></div>
</div></section>
</Layout>
