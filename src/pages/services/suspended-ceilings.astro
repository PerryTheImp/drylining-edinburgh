---
import Layout from '../../layouts/Layout.astro';
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "serviceType": "Suspended Ceilings",
      "provider": { "@type": "LocalBusiness", "name": "Drylining Edinburgh", "@id": "https://dryliningedinburgh.co.uk/#business" },
      "areaServed": { "@type": "City", "name": "Edinburgh" },
      "description": "Professional suspended ceiling installation in Edinburgh. Drop ceilings for offices, retail, and healthcare. Improves acoustics and hides services."
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://dryliningedinburgh.co.uk/" },
        { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://dryliningedinburgh.co.uk/services/" },
        { "@type": "ListItem", "position": 3, "name": "Suspended Ceilings", "item": "https://dryliningedinburgh.co.uk/services/suspended-ceilings/" }
      ]
    }
  ]
};
---
<Layout title="Suspended Ceilings Edinburgh | Drop Ceiling Installation" description="Expert suspended ceiling installation in Edinburgh. Clean, modern drop ceilings for offices, retail, and healthcare. Improves acoustics and hides services. Free quotes." canonical="/services/suspended-ceilings/" schema={schema}>
<section style="position:relative;min-height:400px;display:flex;align-items:center;background:linear-gradient(135deg,#1a1a2e 0%,#16213e 100%);overflow:hidden;">
  <img src="/images/service-ceiling.svg" alt="Suspended ceiling installation in Edinburgh" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.25;">
  <div class="container" style="position:relative;z-index:1;text-align:center;">
    <h1 style="font-size:2.5rem;font-weight:800;color:var(--white);margin-bottom:1rem;">Suspended Ceilings in Edinburgh</h1>
    <p style="font-size:1.0625rem;color:rgba(255,255,255,0.85);max-width:700px;margin:0 auto;">Install clean, modern suspended ceilings that hide services, improve acoustics, and enhance lighting. Ideal for offices, retail, and healthcare.</p>
  </div>
</section>
<section class="section"><div class="container" style="max-width:900px;">
<p style="font-size:1.0625rem;color:var(--text);line-height:1.8;margin-bottom:1.5rem;">Suspended ceilings are a practical and cost-effective way to modernise interior spaces while hiding ductwork, cabling, and pipes. At <strong>Drylining Edinburgh</strong>, we install high-quality suspended ceiling systems for offices, retail units, healthcare facilities, and residential properties across Edinburgh and the Lothians.</p>
<img src="/images/service-ceiling.svg" alt="Modern suspended ceiling installation in Edinburgh office" style="border-radius:var(--radius);width:100%;max-width:800px;margin:2rem auto;display:block;box-shadow:var(--shadow-lg);">
<h2 style="font-size:1.75rem;font-weight:700;color:var(--secondary);margin:2.5rem 0 1rem;">Benefits of Suspended Ceilings</h2>
<ul style="list-style:disc;padding-left:1.5rem;color:var(--text);line-height:1.8;font-size:1.0625rem;"><li>Hide electrical, plumbing, and HVAC services</li><li>Improve room acoustics with acoustic ceiling tiles</li><li>Enhance lighting distribution with integrated fixtures</li><li>Easy access for maintenance and repairs</li><li>Fire-rated and moisture-resistant options available</li><li>Quick installation with minimal disruption</li></ul>
<h2 style="font-size:1.75rem;font-weight:700;color:var(--secondary);margin:2.5rem 0 1rem;">Our Suspended Ceiling Process</h2>
<p style="font-size:1.0625rem;color:var(--text);line-height:1.8;margin-bottom:1.5rem;">We begin with a detailed survey of your space to determine the best ceiling system for your needs. Our team then installs the grid framework, fits the ceiling tiles, and integrates lighting and ventilation as required. Every installation is completed to building regulation standards and backed by our workmanship guarantee.</p>
<div style="margin-top:2.5rem;text-align:center;"><a href="/get-quote/" class="btn btn-primary" style="font-size:1.0625rem;padding:1rem 2.5rem;">Get a Free Ceiling Quote</a></div>
</div></section>
</Layout>
