---
import Layout from '../../layouts/Layout.astro';
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "serviceType": "Partition Walls",
      "provider": { "@type": "LocalBusiness", "name": "Drylining Edinburgh", "@id": "https://dryliningedinburgh.co.uk/#business" },
      "areaServed": { "@type": "City", "name": "Edinburgh" },
      "description": "Professional partition wall installation in Edinburgh. Metal stud and timber partitions for homes, offices, and retail. Sound-rated and fire-rated options."
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://dryliningedinburgh.co.uk/" },
        { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://dryliningedinburgh.co.uk/services/" },
        { "@type": "ListItem", "position": 3, "name": "Partition Walls", "item": "https://dryliningedinburgh.co.uk/services/partition-walls/" }
      ]
    }
  ]
};
---
<Layout title="Partition Walls Edinburgh | Metal Stud & Drywall Partitions" description="Expert partition wall installation in Edinburgh. Metal stud and timber partition walls for homes, offices, and retail spaces. Sound-rated and fire-rated options. Free quotes." canonical="/services/partition-walls/" schema={schema}>
<section style="position:relative;min-height:400px;display:flex;align-items:center;background:linear-gradient(135deg,#1a1a2e 0%,#16213e 100%);overflow:hidden;">
  <img src="/images/service-partition.jpg" alt="Partition wall installation in Edinburgh office" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.25;">
  <div class="container" style="position:relative;z-index:1;text-align:center;">
    <h1 style="font-size:2.5rem;font-weight:800;color:var(--white);margin-bottom:1rem;">Partition Walls in Edinburgh</h1>
    <p style="font-size:1.0625rem;color:rgba(255,255,255,0.85);max-width:700px;margin:0 auto;">Build durable, cost-effective partition walls to divide open-plan offices, retail units, and homes. Sound-rated and fire-rated options available.</p>
  </div>
</section>
<section class="section"><div class="container" style="max-width:900px;">
<p style="font-size:1.0625rem;color:var(--text);line-height:1.8;margin-bottom:1.5rem;">Partition walls are one of the most versatile ways to reconfigure interior space without major structural work. At <strong>Drylining Edinburgh</strong>, we install both metal stud and timber-framed partition walls for residential, commercial, and industrial properties across Edinburgh and the Lothians.</p>
<img src="/images/service-partition.jpg" alt="Professional partition wall installation in Edinburgh" style="border-radius:var(--radius);width:100%;max-width:800px;margin:2rem auto;display:block;box-shadow:var(--shadow-lg);">
<h2 style="font-size:1.75rem;font-weight:700;color:var(--secondary);margin:2.5rem 0 1rem;">Types of Partition Walls We Install</h2>
<ul style="list-style:disc;padding-left:1.5rem;color:var(--text);line-height:1.8;font-size:1.0625rem;"><li><strong>Metal stud partitions</strong> — Lightweight, strong, and fire-resistant. Ideal for offices and commercial spaces.</li><li><strong>Timber stud partitions</strong> — Cost-effective and easy to modify. Great for residential projects.</li><li><strong>Sound-rated partitions</strong> — With acoustic insulation for meeting rooms, bedrooms, and studios.</li><li><strong>Fire-rated partitions</strong> — Compliant with building regulations for safety-critical areas.</li></ul>
<h2 style="font-size:1.75rem;font-weight:700;color:var(--secondary);margin:2.5rem 0 1rem;">Where We Install Partition Walls</h2>
<p style="font-size:1.0625rem;color:var(--text);line-height:1.8;margin-bottom:1.5rem;">Our partition wall services cover Edinburgh city centre, Leith, Livingston, Falkirk, Dalkeith, Musselburgh, and all surrounding areas. Whether you need a single dividing wall in a flat or a full office fit-out with multiple rooms, we have the experience and team to deliver on time and on budget.</p>
<div style="margin-top:2.5rem;text-align:center;"><a href="/get-quote/" class="btn btn-primary" style="font-size:1.0625rem;padding:1rem 2.5rem;">Get a Free Partition Wall Quote</a></div>
</div></section>
</Layout>
