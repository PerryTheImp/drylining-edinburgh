---
import Layout from '../../layouts/Layout.astro';
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "serviceType": "Metal Stud Partitioning",
      "provider": { "@type": "LocalBusiness", "name": "Drylining Edinburgh", "@id": "https://dryliningedinburgh.co.uk/#business" },
      "areaServed": { "@type": "City", "name": "Edinburgh" },
      "description": "Metal stud partitioning in Edinburgh. Lightweight, strong metal frame walls for commercial fit-outs. Fire-rated and acoustic options available."
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://dryliningedinburgh.co.uk/" },
        { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://dryliningedinburgh.co.uk/services/" },
        { "@type": "ListItem", "position": 3, "name": "Metal Stud Partitioning", "item": "https://dryliningedinburgh.co.uk/services/metal-stud-partitioning/" }
      ]
    }
  ]
};
---
<Layout title="Metal Stud Partitioning Edinburgh | Commercial Partition Walls" description="Expert metal stud partitioning in Edinburgh. Lightweight, strong metal frame walls for commercial fit-outs. Faster to install than timber framing. Free quotes." canonical="/services/metal-stud-partitioning/" schema={schema}>
<section style="position:relative;min-height:400px;display:flex;align-items:center;background:linear-gradient(135deg,#1a1a2e 0%,#16213e 100%);overflow:hidden;">
  <img src="/images/service-metal-stud.jpg" alt="Metal stud partitioning installation in Edinburgh" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.25;">
  <div class="container" style="position:relative;z-index:1;text-align:center;">
    <h1 style="font-size:2.5rem;font-weight:800;color:var(--white);margin-bottom:1rem;">Metal Stud Partitioning in Edinburgh</h1>
    <p style="font-size:1.0625rem;color:rgba(255,255,255,0.85);max-width:700px;margin:0 auto;">Lightweight, strong metal stud partitions perfect for commercial fit-outs. Faster to install and easier to modify than traditional timber framing.</p>
  </div>
</section>
<section class="section"><div class="container" style="max-width:900px;">
<p style="font-size:1.0625rem;color:var(--text);line-height:1.8;margin-bottom:1.5rem;">Metal stud partitioning is the go-to choice for modern commercial interiors. Unlike timber framing, metal studs are resistant to warping, rot, and pests, making them ideal for offices, retail units, healthcare facilities, and industrial spaces across Edinburgh.</p>
<img src="/images/service-metal-stud.jpg" alt="Metal stud partition wall construction in Edinburgh" style="border-radius:var(--radius);width:100%;max-width:800px;margin:2rem auto;display:block;box-shadow:var(--shadow-lg);">
<h2 style="font-size:1.75rem;font-weight:700;color:var(--secondary);margin:2.5rem 0 1rem;">Advantages of Metal Stud Partitions</h2>
<ul style="list-style:disc;padding-left:1.5rem;color:var(--text);line-height:1.8;font-size:1.0625rem;"><li><strong>Lightweight yet strong</strong> — Easier to transport and faster to install than timber</li><li><strong>Fire-resistant</strong> — Non-combustible material improves building safety</li><li><strong>Straight and true</strong> — No warping or twisting over time</li><li><strong>Easy to modify</strong> — Simple to relocate or reconfigure walls later</li><li><strong>Recyclable</strong> — Environmentally friendly material choice</li></ul>
<h2 style="font-size:1.75rem;font-weight:700;color:var(--secondary);margin:2.5rem 0 1rem;">Our Metal Stud Partitioning Service</h2>
<p style="font-size:1.0625rem;color:var(--text);line-height:1.8;margin-bottom:1.5rem;">We supply and install complete metal stud partition systems including C-stud and U-track framing, plasterboard cladding, insulation, fire-rated boards, and acoustic treatments. Our Edinburgh-based team works to tight deadlines and delivers professional results every time.</p>
<div style="margin-top:2.5rem;text-align:center;"><a href="/get-quote/" class="btn btn-primary" style="font-size:1.0625rem;padding:1rem 2.5rem;">Get a Free Metal Stud Quote</a></div>
</div></section>
</Layout>
