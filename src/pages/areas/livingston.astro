---
import Layout from '../../layouts/Layout.astro';
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "name": "Drylining Edinburgh",
      "@id": "https://dryliningedinburgh.co.uk/#business",
      "areaServed": { "@type": "City", "name": "Livingston" },
      "serviceType": "Drylining, Partition Walls, Suspended Ceilings"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://dryliningedinburgh.co.uk/" },
        { "@type": "ListItem", "position": 2, "name": "Areas", "item": "https://dryliningedinburgh.co.uk/areas/" },
        { "@type": "ListItem", "position": 3, "name": "Livingston", "item": "https://dryliningedinburgh.co.uk/areas/livingston/" }
      ]
    }
  ]
};
---
<Layout title="Drylining Livingston | Partition Walls & Suspended Ceilings" description="Drylining contractors in Livingston. Partition walls, suspended ceilings, plasterboard installation for homes and businesses. Free quotes, fast response." canonical="/areas/livingston/" schema={schema}>
<section style="position:relative;min-height:400px;display:flex;align-items:center;background:linear-gradient(135deg,#1a1a2e 0%,#16213e 100%);overflow:hidden;">
  <img src="/images/area-livingston.svg" alt="Livingston with drylining services" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.25;">
  <div class="container" style="position:relative;z-index:1;text-align:center;">
    <h1 style="font-size:2.5rem;font-weight:800;color:var(--white);margin-bottom:1rem;">Drylining in Livingston</h1>
    <p style="font-size:1.0625rem;color:rgba(255,255,255,0.85);max-width:700px;margin:0 auto;">Professional drylining services in Livingston. Residential and commercial partition walls, suspended ceilings, and plasterboard installation.</p>
  </div>
</section>
<section class="section"><div class="container" style="max-width:900px;">
<p style="font-size:1.0625rem;color:var(--text);line-height:1.8;margin-bottom:1.5rem;">Livingston is a thriving town in West Lothian with a mix of residential estates, retail parks, and industrial units. <strong>Drylining Edinburgh</strong> serves Livingston with the same high-quality drylining, partition wall, and suspended ceiling services we provide across the Lothians.</p>
<p style="font-size:1.0625rem;color:var(--text);line-height:1.8;margin-bottom:1.5rem;">Whether you are renovating a home in Craigshill, fitting out a retail unit at the Almondvale Centre, or installing office partitions in a business park, our experienced team delivers professional results on time and on budget.</p>
<h2 style="font-size:1.75rem;font-weight:700;color:var(--secondary);margin:2.5rem 0 1rem;">Services Available in Livingston</h2>
<ul style="list-style:disc;padding-left:1.5rem;color:var(--text);line-height:1.8;font-size:1.0625rem;"><li>Residential drylining and plasterboard installation</li><li>Partition walls for homes and offices</li><li>Suspended ceilings for retail and commercial spaces</li><li>Metal stud partitioning for industrial units</li><li>Taping & jointing for seamless finishes</li></ul>
<div style="margin-top:2.5rem;text-align:center;"><a href="/get-quote/" class="btn btn-primary" style="font-size:1.0625rem;padding:1rem 2.5rem;">Get a Free Livingston Quote</a></div>
</div></section>
</Layout>
