---
import Layout from '../../layouts/Layout.astro';
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "name": "Drylining Edinburgh",
      "@id": "https://dryliningedinburgh.co.uk/#business",
      "areaServed": { "@type": "City", "name": "Leith" },
      "serviceType": "Drylining, Partition Walls, Suspended Ceilings"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://dryliningedinburgh.co.uk/" },
        { "@type": "ListItem", "position": 2, "name": "Areas", "item": "https://dryliningedinburgh.co.uk/areas/" },
        { "@type": "ListItem", "position": 3, "name": "Leith", "item": "https://dryliningedinburgh.co.uk/areas/leith/" }
      ]
    }
  ]
};
---
<Layout title="Drylining Leith | Partition Walls & Suspended Ceilings" description="Drylining contractors in Leith and the Shore. Partition walls, suspended ceilings, plasterboard installation for homes and businesses. Free quotes." canonical="/areas/leith/" schema={schema}>
<section style="position:relative;min-height:400px;display:flex;align-items:center;background:linear-gradient(135deg,#1a1a2e 0%,#16213e 100%);overflow:hidden;">
  <img src="/images/area-leith.svg" alt="Leith waterfront with drylining services" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.25;">
  <div class="container" style="position:relative;z-index:1;text-align:center;">
    <h1 style="font-size:2.5rem;font-weight:800;color:var(--white);margin-bottom:1rem;">Drylining in Leith</h1>
    <p style="font-size:1.0625rem;color:rgba(255,255,255,0.85);max-width:700px;margin:0 auto;">Professional drylining, partition walls, and suspended ceiling services in Leith and the Shore. Fast quotes, quality workmanship.</p>
  </div>
</section>
<section class="section"><div class="container" style="max-width:900px;">
<p style="font-size:1.0625rem;color:var(--text);line-height:1.8;margin-bottom:1.5rem;">Leith is one of Edinburgh's most vibrant and rapidly developing areas, with a mix of historic tenements, modern apartments, and thriving commercial spaces along the Shore. At <strong>Drylining Edinburgh</strong>, we provide expert drylining services tailored to Leith's diverse property landscape.</p>
<p style="font-size:1.0625rem;color:var(--text);line-height:1.8;margin-bottom:1.5rem;">From renovating flats in traditional tenements to fitting out new restaurants and offices along the waterfront, our experienced team understands the unique requirements of working in Leith. We deliver professional results with respect for the area's character and your property.</p>
<h2 style="font-size:1.75rem;font-weight:700;color:var(--secondary);margin:2.5rem 0 1rem;">Drylining Services in Leith</h2>
<ul style="list-style:disc;padding-left:1.5rem;color:var(--text);line-height:1.8;font-size:1.0625rem;"><li>Drylining for residential renovations and new builds</li><li>Partition walls for open-plan conversions</li><li>Suspended ceilings for commercial units and offices</li><li>Metal stud partitioning for retail fit-outs</li><li>Plasterboard and taping & jointing</li></ul>
<div style="margin-top:2.5rem;text-align:center;"><a href="/get-quote/" class="btn btn-primary" style="font-size:1.0625rem;padding:1rem 2.5rem;">Get a Free Leith Quote</a></div>
</div></section>
</Layout>
