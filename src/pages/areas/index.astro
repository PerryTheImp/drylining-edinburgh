---
import Layout from '../../layouts/Layout.astro';
import AreasGrid from '../../components/AreasGrid.astro';

const areas = [
  { name: 'Edinburgh', slug: 'edinburgh', desc: 'Full drylining services across Edinburgh city centre, New Town, Old Town, Leith, and all surrounding neighbourhoods.' },
  { name: 'Leith', slug: 'leith', desc: 'Professional partition walls and drylining for homes and businesses throughout Leith and the Shore.' },
  { name: 'Livingston', slug: 'livingston', desc: 'Drylining, partition walls, and suspended ceilings for homes and businesses in Livingston and West Lothian.' },
  { name: 'Falkirk', slug: 'falkirk', desc: 'Reliable drylining contractors covering Falkirk and the surrounding Central Scotland area.' },
  { name: 'Dalkeith', slug: 'dalkeith', desc: 'Drylining, partition walls, and plasterboard installation for Dalkeith and Midlothian.' },
  { name: 'Musselburgh', slug: 'musselburgh', desc: 'Drylining, partition walls, and suspended ceilings for Musselburgh and East Lothian.' },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": "https://dryliningedinburgh.co.uk/#business",
      "name": "Drylining Edinburgh",
      "areaServed": areas.map(a => ({ "@type": "City", "name": a.name }))
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://dryliningedinburgh.co.uk/" },
        { "@type": "ListItem", "position": 2, "name": "Areas", "item": "https://dryliningedinburgh.co.uk/areas/" }
      ]
    }
  ]
};
---

<Layout title="Drylining Areas | Edinburgh, Leith & Surrounding Towns" description="Drylining services across Edinburgh, Leith, Livingston, Falkirk, Dalkeith, and Musselburgh. Free quotes, fast response." canonical="/areas/" schema={schema}>
  <section style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); padding: 5rem 0; text-align: center;">
    <div class="container">
      <h1 style="font-size: 2.75rem; font-weight: 800; color: var(--white); margin-bottom: 1rem;">Areas We Cover</h1>
      <p style="font-size: 1.125rem; color: rgba(255,255,255,0.85); max-width: 700px; margin: 0 auto;">We provide drylining, partition walls, and suspended ceiling services across Edinburgh and the Lothians. If your area is not listed, contact us. We likely still cover it.</p>
    </div>
  </section>

  <section class="section" style="background: var(--accent);">
    <div class="container">
      <AreasGrid areas={areas} />
    </div>
  </section>

  <section class="section">
    <div class="container" style="text-align: center;">
      <h2 style="font-size: 2rem; font-weight: 800; color: var(--secondary); margin-bottom: 1rem;">Do Not See Your Area?</h2>
      <p style="color: var(--text-light); max-width: 600px; margin: 0 auto 2rem; font-size: 1.0625rem;">We travel across the Lothians and Central Scotland for commercial and large residential projects. Get in touch and we will let you know if we can help.</p>
      <a href="/get-quote/" class="btn btn-primary" style="font-size: 1.0625rem; padding: 1rem 2.5rem;">Get a Free Quote</a>
    </div>
  </section>
</Layout>
