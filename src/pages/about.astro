---
import Layout from '../layouts/Layout.astro';
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "name": "Drylining Edinburgh",
      "url": "https://dryliningedinburgh.co.uk",
      "logo": "https://dryliningedinburgh.co.uk/logo.png",
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "0131-XXX-XXXX",
        "contactType": "customer service",
        "areaServed": "Edinburgh, Leith, Livingston, Falkirk, Dalkeith, Musselburgh"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://dryliningedinburgh.co.uk/" },
        { "@type": "ListItem", "position": 2, "name": "About", "item": "https://dryliningedinburgh.co.uk/about/" }
      ]
    }
  ]
};
---
<Layout title="About Us | Drylining Edinburgh — Expert Contractors" description="Learn about Drylining Edinburgh. CSCS-accredited drylining contractors serving Edinburgh, Leith, Livingston, Falkirk, and surrounding areas. £1M insured, free quotes, 24h response." canonical="/about/" schema={schema}>
<section style="position:relative;min-height:400px;display:flex;align-items:center;background:linear-gradient(135deg,#1a1a2e 0%,#16213e 100%);overflow:hidden;">
  <img src="/images/about-team.svg" alt="The Drylining Edinburgh team at work" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.25;">
  <div class="container" style="position:relative;z-index:1;text-align:center;">
    <h1 style="font-size:2.5rem;font-weight:800;color:var(--white);margin-bottom:1rem;">About Drylining Edinburgh</h1>
    <p style="font-size:1.0625rem;color:rgba(255,255,255,0.85);max-width:700px;margin:0 auto;">Your trusted drylining contractors in Edinburgh and Central Scotland. Quality workmanship, transparent pricing, and a commitment to every project.</p>
  </div>
</section>
<section class="section"><div class="container" style="max-width:900px;">
<p style="font-size:1.0625rem;color:var(--text);line-height:1.8;margin-bottom:1.5rem;"><strong>Drylining Edinburgh</strong> is a team of experienced drylining contractors dedicated to delivering high-quality partition walls, suspended ceilings, and plasterboard installations across Edinburgh, Leith, Livingston, Falkirk, Dalkeith, Musselburgh, and the surrounding Lothians and Central Scotland region. We combine traditional craftsmanship with modern techniques to produce interiors that look exceptional and stand the test of time.</p>
<p style="font-size:1.0625rem;color:var(--text);line-height:1.8;margin-bottom:1.5rem;">Founded on the principles of honesty, reliability, and quality, we have built a reputation as one of the most trusted drylining companies in Scotland's capital. Every member of our team is CSCS accredited, fully trained, and committed to maintaining the highest standards of workmanship and site safety.</p>
<h2 style="font-size:1.75rem;font-weight:700;color:var(--secondary);margin:2.5rem 0 1rem;">What We Believe In</h2>
<p style="font-size:1.0625rem;color:var(--text);line-height:1.8;margin-bottom:1.5rem;">We believe that great drylining is about more than just fixing boards to walls. It is about understanding the client's vision, respecting their property, and delivering a finish that exceeds expectations. Whether it is a single-room renovation or a multi-floor commercial fit-out, we treat every project with the same level of care and professionalism.</p>
<h2 style="font-size:1.75rem;font-weight:700;color:var(--secondary);margin:2.5rem 0 1rem;">Our Credentials</h2>
<ul style="list-style:disc;padding-left:1.5rem;color:var(--text);line-height:1.8;font-size:1.0625rem;"><li>CSCS accredited contractors on every project</li><li>£1 million public liability insurance</li><li>Fully compliant with health and safety regulations</li><li>Years of experience in residential and commercial drylining</li><li>Transparent pricing with no hidden fees</li><li>Free, no-obligation quotes with fast response times</li></ul>
<h2 style="font-size:1.75rem;font-weight:700;color:var(--secondary);margin:2.5rem 0 1rem;">Areas We Serve</h2>
<p style="font-size:1.0625rem;color:var(--text);line-height:1.8;margin-bottom:1.5rem;">We are based in Edinburgh and regularly work in Leith, Livingston, Falkirk, Dalkeith, Musselburgh, and surrounding towns and villages. For larger commercial projects, we are happy to travel further across Central Scotland.</p>
<div style="margin-top:2.5rem;text-align:center;"><a href="/get-quote/" class="btn btn-primary" style="font-size:1.0625rem;padding:1rem 2.5rem;">Get a Free Quote</a></div>
</div></section>
</Layout>
