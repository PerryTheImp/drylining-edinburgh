---

<Layout
  title="Drylining Edinburgh | Expert Partition Walls & Suspended Ceilings"
  description="Professional drylining contractors in Edinburgh. Partition walls, suspended ceilings, metal stud framing, plasterboard installation. Free quotes, CSCS accredited, fully insured."
  canonical="/"
  schema={schema}
>
  <!-- Hero Section with Multi-Step Form -->
  <section style="position: relative; min-height: 620px; display: flex; align-items: center; background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); overflow: hidden;">
    <img src="/images/hero-main.jpg" alt="Construction site with drylining work in Edinburgh" style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.25;" />
    <div class="container" style="position: relative; z-index: 1; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;">
      <div>
        <div style="display: inline-block; background: rgba(196,30,58,0.2); color: var(--primary); padding: 0.375rem 1rem; border-radius: 9999px; font-size: 0.875rem; font-weight: 600; margin-bottom: 1.5rem; border: 1px solid rgba(196,30,58,0.3);">CSCS Accredited • £1M Insured</div>
        <h1 style="font-size: 3.5rem; font-weight: 800; color: var(--white); line-height: 1.1; margin-bottom: 1.25rem;">Drylining Edinburgh<br/><span style="color: var(--primary);">Partition Walls & Ceilings</span></h1>
        <p style="font-size: 1.125rem; color: rgba(255,255,255,0.85); max-width: 500px; line-height: 1.7; margin-bottom: 2rem;">Expert drylining contractors serving Edinburgh, Leith, Livingston, Falkirk, and surrounding areas. Free quotes, fast turnaround, and solid results guaranteed.</p>
        <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
          <a href="/get-quote/" class="btn btn-primary" style="font-size: 1.0625rem; padding: 1rem 2.25rem;">Get a Free Quote</a>
          <a href="tel:08008203090" class="btn btn-outline" style="border-color: rgba(255,255,255,0.4); color: var(--white); font-size: 1.0625rem; padding: 1rem 2.25rem;">FREEPHONE 0800 820 3090</a>
        </div>
      </div>
      
      <div style="background: var(--white); border-radius: var(--radius); padding: 2rem; box-shadow: var(--shadow-lg);">
        <div style="background: var(--white); border-radius: var(--radius); padding: 2rem; box-shadow: var(--shadow-lg);">
          <h3 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 1.25rem; color: var(--secondary);">Quick Quote Request</h3>
          <form action="https://script.google.com/macros/s/AKfycbx2ROgDcHu3ArLmfqPETQYCkFn_5YP6fy1WfZMbynAZsoARpnMRntm5iLlgKSFSJBkG/exec" method="POST" id="heroQuoteForm" style="display: flex; flex-direction: column; gap: 0.875rem;">
            <input type="hidden" name="source" value="dryliningedinburgh.co.uk" />
            <input type="hidden" name="city" value="Edinburgh" />
            <input type="text" name="name" placeholder="Your name" required style="padding: 0.75rem 1rem; border: 1px solid var(--border); border-radius: var(--radius); font-size: 0.9375rem; font-family: inherit;" />
            <input type="tel" name="phone" placeholder="Phone number" required style="padding: 0.75rem 1rem; border: 1px solid var(--border); border-radius: var(--radius); font-size: 0.9375rem; font-family: inherit;" />
            <input type="email" name="email" placeholder="Email address" style="padding: 0.75rem 1rem; border: 1px solid var(--border); border-radius: var(--radius); font-size: 0.9375rem; font-family: inherit;" />
            <select name="service" required style="padding: 0.75rem 1rem; border: 1px solid var(--border); border-radius: var(--radius); font-size: 0.9375rem; font-family: inherit; background: var(--white); color: var(--text);">
              <option value="" disabled selected>Select a service</option>
              <option>Drylining Contractors</option>
              <option>Partition Walls</option>
              <option>Metal Stud Partitioning</option>
              <option>Suspended Ceilings</option>
              <option>Plasterboard Installation</option>
              <option>Taping & Jointing</option>
              <option>Commercial Drylining</option>
              <option>Office Drylining</option>
            </select>
            <textarea name="details" placeholder="Project details (optional)" rows="3" style="padding: 0.75rem 1rem; border: 1px solid var(--border); border-radius: var(--radius); font-size: 0.9375rem; font-family: inherit; resize: vertical;"></textarea>
            <button type="submit" class="btn btn-primary" id="heroSubmitBtn" style="width: 100%; margin-top: 0.25rem;">Request Free Quote</button>
            <div id="heroFormMessage" style="font-size: 0.875rem; margin-top: 0.5rem; display: none;"></div>
          </form>
        </div>
      </div>
    </div>
  </section>

  <TrustBar />

  <!-- Video Section -->
  <section class="section" style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);">
    <div class="container" style="text-align: center;">
      <h2 class="section-title" style="color: var(--white);">See Our Work in Action</h2>
      <p style="font-size: 1.125rem; color: rgba(255,255,255,0.85); max-width: 600px; margin: 0 auto 2rem;">See our team at work on drylining, partition walls, and suspended ceilings across Edinburgh and the Lothians.</p>
      <div style="position: relative; max-width: 900px; margin: 0 auto; border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow-lg);">
        <video controls poster="/images/hero-main.jpg" style="width: 100%; display: block;" preload="metadata">
          <source src="/videos/drylining-edinburgh-promo.mp4" type="video/mp4">
          Your browser does not support the video tag.
        </video>
      </div>
      <p style="font-size: 0.875rem; color: rgba(255,255,255,0.6); margin-top: 1rem;">Drylining Edinburgh. Professional partition walls, suspended ceilings, and plasterboard installation across Scotland's capital.</p>
    </div>
  </section>

  <!-- Services Section -->
  <section class="section" style="background: var(--accent);">
    <div class="container">
      <h2 class="section-title">Our Drylining Services</h2>
      <p class="section-subtitle">From residential renovations to large commercial fit-outs, we deliver every drylining service you need. All under one roof, fully accredited, and fully insured.</p>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem;">
        {services.map(s => (
          <FlipCard title={s.title} description={s.description} link={s.link} icon={s.icon} />
        ))}
      </div>
      <div style="text-align: center; margin-top: 3rem;">
        <a href="/services/" class="btn btn-secondary">View All Services</a>
      </div>
    </div>
  </section>

  <!-- Areas Section -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Areas We Cover</h2>
      <p class="section-subtitle">We provide drylining, partition walls, and suspended ceiling services across Edinburgh and the Lothians. If your area is not listed, get in touch. We likely still cover it.</p>
      <AreasGrid areas={areas} />
      <div style="text-align: center; margin-top: 3rem;">
        <a href="/areas/" class="btn btn-secondary">View All Areas</a>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="section" style="background: var(--accent);">
    <div class="container">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;">
        <div>
          <img src="/images/service-drylining.jpg" alt="Professional drylining contractor at work in Edinburgh" style="border-radius: var(--radius); width: 100%; box-shadow: var(--shadow-lg);" />
        </div>
        <div>
          <h2 class="section-title">Why Choose Drylining Edinburgh?</h2>
          <p style="color: var(--text-light); margin-bottom: 2rem; font-size: 1.0625rem; line-height: 1.7;">We are a team of experienced tradespeople who focus on getting the job done right. Here is what sets us apart:</p>
          <ul style="list-style: none; display: flex; flex-direction: column; gap: 1.25rem;">
            <li style="display: flex; gap: 1rem; align-items: flex-start;">
              <span style="background: var(--primary); color: var(--white); width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.875rem; flex-shrink: 0;">1</span>
              <div>
                <strong style="color: var(--secondary); display: block; margin-bottom: 0.25rem;">CSCS Accredited Team</strong>
                <span style="color: var(--text-light); font-size: 0.9375rem;">Every contractor on our team holds valid CSCS cards and site safety certifications.</span>
              </div>
            </li>
            <li style="display: flex; gap: 1rem; align-items: flex-start;">
              <span style="background: var(--primary); color: var(--white); width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.875rem; flex-shrink: 0;">2</span>
              <div>
                <strong style="color: var(--secondary); display: block; margin-bottom: 0.25rem;">£1M Public Liability Insurance</strong>
                <span style="color: var(--text-light); font-size: 0.9375rem;">Full insurance coverage on every project, giving you total peace of mind.</span>
              </div>
            </li>
            <li style="display: flex; gap: 1rem; align-items: flex-start;">
              <span style="background: var(--primary); color: var(--white); width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.875rem; flex-shrink: 0;">3</span>
              <div>
                <strong style="color: var(--secondary); display: block; margin-bottom: 0.25rem;">Free, No-Obligation Quotes</strong>
                <span style="color: var(--text-light); font-size: 0.9375rem;">Transparent pricing with no hidden fees. We quote honestly and stick to it.</span>
              </div>
            </li>
            <li style="display: flex; gap: 1rem; align-items: flex-start;">
              <span style="background: var(--primary); color: var(--white); width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.875rem; flex-shrink: 0;">4</span>
              <div>
                <strong style="color: var(--secondary); display: block; margin-bottom: 0.25rem;">24-Hour Response Time</strong>
                <span style="color: var(--text-light); font-size: 0.9375rem;">We aim to respond to all enquiries within 24 hours, often the same day.</span>
              </div>
            </li>
            <li style="display: flex; gap: 1rem; align-items: flex-start;">
              <span style="background: var(--primary); color: var(--white); width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.875rem; flex-shrink: 0;">5</span>
              <div>
                <strong style="color: var(--secondary); display: block; margin-bottom: 0.25rem;">Clean, Professional Work</strong>
                <span style="color: var(--text-light); font-size: 0.9375rem;">We leave sites tidy and respect your property, whether residential or commercial.</span>
              </div>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%); padding: 5rem 0; text-align: center;">
    <div class="container">
      <h2 style="font-size: 2.5rem; font-weight: 800; color: var(--white); margin-bottom: 1rem;">Ready to Start Your Project?</h2>
      <p style="font-size: 1.125rem; color: rgba(255,255,255,0.9); max-width: 600px; margin: 0 auto 2rem;">Get your free, no-obligation quote today. We aim to respond within 24 hours to all enquiries across Edinburgh and the surrounding areas.</p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="/get-quote/" class="btn btn-white" style="font-size: 1.0625rem; padding: 1rem 2.5rem;">Get Your Free Quote</a>
        <a href="tel:08008203090" class="btn btn-outline" style="border-color: rgba(255,255,255,0.5); color: var(--white); font-size: 1.0625rem; padding: 1rem 2.5rem;">FREEPHONE 0800 820 3090</a>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section">
    <div class="container" style="max-width: 800px;">
      <h2 class="section-title" style="text-align: center;">Frequently Asked Questions</h2>
      <p class="section-subtitle" style="text-align: center; margin: 0 auto 3rem;">Everything you need to know about our drylining services in Edinburgh.</p>
      {faqs.map(f => (
        <FAQItem question={f.question} answer={f.answer} />
      ))}
      <div style="text-align: center; margin-top: 2.5rem;">
        <a href="/faq/" class="btn btn-outline">View All FAQs</a>
      </div>
    </div>
  </section>

  <!-- Schema Markup -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Drylining Edinburgh",
      "url": "https://dryliningedinburgh.co.uk",
      "telephone": "+448008203090",
      "knowsAbout": [
        "https://en.wikipedia.org/wiki/Drywall",
        "https://en.wikipedia.org/wiki/Plaster",
        "https://en.wikipedia.org/wiki/Partition_wall",
        "https://en.wikipedia.org/wiki/Building_regulations_in_the_United_Kingdom",
        "https://en.wikipedia.org/wiki/Construction_worker",
        "https://en.wikipedia.org/wiki/General_contractor",
        "https://en.wikipedia.org/wiki/Cold-formed_steel",
        "https://en.wikipedia.org/wiki/Dropped_ceiling"
      ],
      "areaServed": {
        "@type": "Place",
        "name": "Edinburgh",
        "sameAs": [
          "https://en.wikipedia.org/wiki/Edinburgh",
          "https://www.wikidata.org/entity/Q23436"
        ]
      }
    }
  </script>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Drylining Edinburgh",
      "@id": "https://dryliningedinburgh.co.uk/#business",
      "url": "https://dryliningedinburgh.co.uk",
      "telephone": "+448008203090",
      "serviceType": "Drylining Services",
      "additionalType": "https://www.wikidata.org/entity/Q213825",
