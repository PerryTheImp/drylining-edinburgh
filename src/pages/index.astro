---
import Layout from '../layouts/Layout.astro';
import FlipCard from '../components/FlipCard.astro';
import TrustBar from '../components/TrustBar.astro';
import AreasGrid from '../components/AreasGrid.astro';
import FAQItem from '../components/FAQItem.astro';
import MultiStepForm from '../components/MultiStepForm.astro';

const services = [
  { title: 'Drylining Contractors', description: 'Expert drylining installation for residential and commercial properties across Edinburgh. We create smooth, paint-ready wall finishes quickly and cleanly.', link: '/services/drylining-contractors/', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>' },
  { title: 'Partition Walls', description: 'Build durable, cost-effective partition walls to divide open-plan offices, retail units, and homes. Sound-rated and fire-rated options available.', link: '/services/partition-walls/', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>' },
  { title: 'Suspended Ceilings', description: 'Install clean, modern suspended ceilings that hide services, improve acoustics, and enhance lighting. Ideal for offices, retail, and healthcare across Edinburgh.', link: '/services/suspended-ceilings/', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M7 12h10"/><path d="M5 18h14"/></svg>' },
  { title: 'Metal Stud Partitioning', description: 'Lightweight, strong metal stud partitions perfect for commercial fit-outs. Faster to install and easier to modify than traditional timber framing.', link: '/services/metal-stud-partitioning/', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="16" height="16" x="4" y="4" rx="2"/><path d="M12 4v16"/><path d="M4 12h16"/></svg>' },
  { title: 'Plasterboard Installation', description: 'Precision plasterboard fitting for walls and ceilings. Seamless joints, professional finishing, and minimal disruption to your project timeline.', link: '/services/plasterboard-installation/', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/></svg>' },
  { title: 'Taping & Jointing', description: 'Smooth, crack-resistant finishes with expert taping and jointing. No need for full plastering — faster, cleaner, and ready for decoration.', link: '/services/taping-and-jointing/', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>' },
];

const areas = [
  { name: 'Edinburgh', slug: 'edinburgh', desc: 'Full drylining services across Edinburgh city centre, New Town, Old Town, Leith, and all surrounding neighbourhoods.' },
  { name: 'Leith', slug: 'leith', desc: 'Professional partition walls and drylining for homes and businesses throughout Leith and the Shore.' },
  { name: 'Livingston', slug: 'livingston', desc: 'Serving residential and commercial clients in Livingston with fast quotes and quality workmanship.' },
  { name: 'Falkirk', slug: 'falkirk', desc: 'Reliable drylining contractors covering Falkirk and the surrounding Central Scotland area.' },
  { name: 'Dalkeith', slug: 'dalkeith', desc: 'Drylining and suspended ceiling installation for Dalkeith businesses and homeowners.' },
  { name: 'Musselburgh', slug: 'musselburgh', desc: 'Experienced drylining teams working across Musselburgh and the surrounding towns.' },
];

const faqs = [
  { question: 'What is drylining and how does it work?', answer: 'Drylining is the process of fixing plasterboard to walls, ceilings, or stud frames without using wet plaster. It creates a smooth surface ready for painting or decorating. Our team measures, cuts, and fixes boards precisely, then tapes and joints the seams for an invisible finish.' },
  { question: 'How long does a typical drylining project take?', answer: 'Most residential rooms can be drylined in 1–2 days. Larger commercial projects depend on scale, but our experienced crews work efficiently to minimise downtime. We provide a clear timeline with every quote.' },
  { question: 'Do you offer free, no-obligation quotes?', answer: 'Yes. We provide completely free quotes for all drylining, partition wall, and suspended ceiling projects in Edinburgh and surrounding areas. Simply fill out our quote form or call us to arrange a site visit.' },
  { question: 'Are your drylining contractors fully insured?', answer: 'Absolutely. We carry £1 million public liability insurance, and all our drylining contractors are CSCS accredited. We also comply with health and safety regulations on every site.' },
  { question: 'Can you work around our business hours?', answer: 'Yes. For commercial and office drylining projects in Edinburgh, we can schedule work outside business hours, during weekends, or in phases to minimise disruption to your operations.' },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": "https://dryliningedinburgh.co.uk/#business",
      "name": "Drylining Edinburgh",
      "url": "https://dryliningedinburgh.co.uk",
      "telephone": "0131-XXX-XXXX",
      "email": "info@dryliningedinburgh.co.uk",
      "areaServed": { "@type": "City", "name": "Edinburgh" },
      "serviceType": "Drylining, Partition Walls, Suspended Ceilings",
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Drylining Services",
        "itemListElement": services.map(s => ({ "@type": "Offer", "itemOffered": { "@type": "Service", "name": s.title } }))
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.question,
        "acceptedAnswer": { "@type": "Answer", "text": f.answer }
      }))
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Home", "item": "https://dryliningedinburgh.co.uk/" }]
    }
  ]
};
---

<Layout
  title="Drylining Edinburgh | Expert Partition Walls & Suspended Ceilings"
  description="Professional drylining contractors in Edinburgh. Partition walls, suspended ceilings, metal stud framing, plasterboard installation. Free quotes, CSCS accredited, fully insured."
  canonical="/"
  schema={schema}
>
  <!-- Hero Section with Multi-Step Form -->
  <section style="position: relative; min-height: 620px; display: flex; align-items: center; background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); overflow: hidden;">
    <img src="/images/hero-main.svg" alt="Construction site with drylining work in Edinburgh" style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.25;" />
    <div class="container" style="position: relative; z-index: 1; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;">
      <div>
        <div style="display: inline-block; background: rgba(196,30,58,0.2); color: var(--primary); padding: 0.375rem 1rem; border-radius: 9999px; font-size: 0.875rem; font-weight: 600; margin-bottom: 1.5rem; border: 1px solid rgba(196,30,58,0.3);">CSCS Accredited • £1M Insured</div>
        <h1 style="font-size: 3.5rem; font-weight: 800; color: var(--white); line-height: 1.1; margin-bottom: 1.25rem;">Drylining Edinburgh<br/><span style="color: var(--primary);">Partition Walls & Ceilings</span></h1>
        <p style="font-size: 1.125rem; color: rgba(255,255,255,0.85); max-width: 500px; line-height: 1.7; margin-bottom: 2rem;">Expert drylining contractors serving Edinburgh, Leith, Livingston, Falkirk, and surrounding areas. Free quotes, fast turnaround, and quality workmanship guaranteed.</p>
        <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
          <a href="/get-quote/" class="btn btn-primary" style="font-size: 1.0625rem; padding: 1rem 2.25rem;">Get a Free Quote</a>
          <a href="tel:0131XXXXXXX" class="btn btn-outline" style="border-color: rgba(255,255,255,0.4); color: var(--white); font-size: 1.0625rem; padding: 1rem 2.25rem;">Call 0131 XXX XXXX</a>
        </div>
      </div>
      
      <div style="background: var(--white); border-radius: var(--radius); padding: 2rem; box-shadow: var(--shadow-lg);">
        <MultiStepForm source="edinburgh-home-hero" />
      </div>
    </div>
  </section>

  <TrustBar />

  <!-- Video Section -->
  <section class="section" style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);">
    <div class="container" style="text-align: center;">
      <h2 class="section-title" style="color: var(--white);">See Our Work in Action</h2>
      <p style="font-size: 1.125rem; color: rgba(255,255,255,0.85); max-width: 600px; margin: 0 auto 2rem;">Watch how our expert team transforms spaces with professional drylining, partition walls, and suspended ceilings across Edinburgh and the Lothians.</p>
      <div style="position: relative; max-width: 900px; margin: 0 auto; border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow-lg);">
        <video controls poster="/images/hero-main.svg" style="width: 100%; display: block;" preload="metadata">
          <source src="/videos/drylining-edinburgh-promo.mp4" type="video/mp4">
          Your browser does not support the video tag.
        </video>
      </div>
      <p style="font-size: 0.875rem; color: rgba(255,255,255,0.6); margin-top: 1rem;">Drylining Edinburgh — Professional partition walls, suspended ceilings, and plasterboard installation across Scotland's capital.</p>
    </div>
  </section>

  <!-- Services Section -->
  <section class="section" style="background: var(--accent);">
    <div class="container">
      <h2 class="section-title">Our Drylining Services</h2>
      <p class="section-subtitle">From residential renovations to large commercial fit-outs, we deliver every drylining service you need — all under one roof, fully accredited, and fully insured.</p>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem;">
        {services.map(s => (
          <FlipCard title={s.title} description={s.description} link={s.link} icon={s.icon} />
        ))}
      </div>
      <div style="text-align: center; margin-top: 3rem;">
        <a href="/services/" class="btn btn-secondary">View All Services</a>
      </div>
    </div>
  </section>

  <!-- Areas Section -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Areas We Cover</h2>
      <p class="section-subtitle">We provide drylining, partition walls, and suspended ceiling services across Edinburgh and the Lothians. If your area is not listed, get in touch — we likely still cover it.</p>
      <AreasGrid areas={areas} />
      <div style="text-align: center; margin-top: 3rem;">
        <a href="/areas/" class="btn btn-secondary">View All Areas</a>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="section" style="background: var(--accent);">
    <div class="container">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;">
        <div>
          <img src="/images/service-drylining.svg" alt="Professional drylining contractor at work in Edinburgh" style="border-radius: var(--radius); width: 100%; box-shadow: var(--shadow-lg);" />
        </div>
        <div>
          <h2 class="section-title">Why Choose Drylining Edinburgh?</h2>
          <p style="color: var(--text-light); margin-bottom: 2rem; font-size: 1.0625rem; line-height: 1.7;">We are not just another drylining company. We are a team of skilled tradespeople who take pride in every board we fix and every seam we tape. Here is what sets us apart:</p>
          <ul style="list-style: none; display: flex; flex-direction: column; gap: 1.25rem;">
            <li style="display: flex; gap: 1rem; align-items: flex-start;">
              <span style="background: var(--primary); color: var(--white); width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.875rem; flex-shrink: 0;">1</span>
              <div>
                <strong style="color: var(--secondary); display: block; margin-bottom: 0.25rem;">CSCS Accredited Team</strong>
                <span style="color: var(--text-light); font-size: 0.9375rem;">Every contractor on our team holds valid CSCS cards and site safety certifications.</span>
              </div>
            </li>
            <li style="display: flex; gap: 1rem; align-items: flex-start;">
              <span style="background: var(--primary); color: var(--white); width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.875rem; flex-shrink: 0;">2</span>
              <div>
                <strong style="color: var(--secondary); display: block; margin-bottom: 0.25rem;">£1M Public Liability Insurance</strong>
                <span style="color: var(--text-light); font-size: 0.9375rem;">Full insurance coverage on every project, giving you total peace of mind.</span>
              </div>
            </li>
            <li style="display: flex; gap: 1rem; align-items: flex-start;">
              <span style="background: var(--primary); color: var(--white); width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.875rem; flex-shrink: 0;">3</span>
              <div>
                <strong style="color: var(--secondary); display: block; margin-bottom: 0.25rem;">Free, No-Obligation Quotes</strong>
                <span style="color: var(--text-light); font-size: 0.9375rem;">Transparent pricing with no hidden fees. We quote honestly and stick to it.</span>
              </div>
            </li>
            <li style="display: flex; gap: 1rem; align-items: flex-start;">
              <span style="background: var(--primary); color: var(--white); width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.875rem; flex-shrink: 0;">4</span>
              <div>
                <strong style="color: var(--secondary); display: block; margin-bottom: 0.25rem;">24-Hour Response Time</strong>
                <span style="color: var(--text-light); font-size: 0.9375rem;">We aim to respond to all enquiries within 24 hours, often the same day.</span>
              </div>
            </li>
            <li style="display: flex; gap: 1rem; align-items: flex-start;">
              <span style="background: var(--primary); color: var(--white); width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.875rem; flex-shrink: 0;">5</span>
              <div>
                <strong style="color: var(--secondary); display: block; margin-bottom: 0.25rem;">Clean, Professional Work</strong>
                <span style="color: var(--text-light); font-size: 0.9375rem;">We leave sites tidy and respect your property — residential or commercial.</span>
              </div>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%); padding: 5rem 0; text-align: center;">
    <div class="container">
      <h2 style="font-size: 2.5rem; font-weight: 800; color: var(--white); margin-bottom: 1rem;">Ready to Transform Your Space?</h2>
      <p style="font-size: 1.125rem; color: rgba(255,255,255,0.9); max-width: 600px; margin: 0 auto 2rem;">Get your free, no-obligation quote today. Our drylining experts are standing by to help with your project in Edinburgh and beyond.</p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="/get-quote/" class="btn btn-white" style="font-size: 1.0625rem; padding: 1rem 2.5rem;">Get Your Free Quote</a>
        <a href="tel:0131XXXXXXX" class="btn btn-outline" style="border-color: rgba(255,255,255,0.5); color: var(--white); font-size: 1.0625rem; padding: 1rem 2.5rem;">Call 0131 XXX XXXX</a>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section">
    <div class="container" style="max-width: 800px;">
      <h2 class="section-title" style="text-align: center;">Frequently Asked Questions</h2>
      <p class="section-subtitle" style="text-align: center; margin: 0 auto 3rem;">Everything you need to know about our drylining services in Edinburgh.</p>
      {faqs.map(f => (
        <FAQItem question={f.question} answer={f.answer} />
      ))}
      <div style="text-align: center; margin-top: 2.5rem;">
        <a href="/faq/" class="btn btn-outline">View All FAQs</a>
      </div>
    </div>
  </section>
</Layout>
