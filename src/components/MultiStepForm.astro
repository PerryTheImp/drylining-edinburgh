---
export interface Props {
  source?: string;
  compact?: boolean;
}
const { source = 'dryliningedinburgh-co-uk', compact = false } = Astro.props;

const services = [
  { id: 'drylining', title: 'Drylining Contractors', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>' },
  { id: 'partition', title: 'Partition Walls', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>' },
  { id: 'ceiling', title: 'Suspended Ceilings', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M7 12h10"/><path d="M5 18h14"/></svg>' },
  { id: 'metal-stud', title: 'Metal Stud Partitioning', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="16" height="16" x="4" y="4" rx="2"/><path d="M12 4v16"/><path d="M4 12h16"/></svg>' },
  { id: 'plasterboard', title: 'Plasterboard Installation', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/></svg>' },
  { id: 'taping', title: 'Taping & Jointing', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>' },
];
---

<div class={`multi-step-form ${compact ? 'compact' : ''}`} data-source={source}>
  <!-- Progress Bar -->
  <div class="form-progress" style="margin-bottom: 2rem;">
    <div style="display: flex; align-items: center; justify-content: space-between; position: relative;">
      <div class="progress-line-bg" style="position: absolute; top: 14px; left: 12%; right: 12%; height: 3px; background: var(--border); z-index: 0;"></div>
      <div class="progress-line-fill" style="position: absolute; top: 14px; left: 12%; height: 3px; background: var(--primary); z-index: 1; transition: width 0.4s ease;"></div>
      {[1, 2, 3].map(step => (
        <div class={`progress-step progress-step-${step}`} style="display: flex; flex-direction: column; align-items: center; gap: 0.375rem; z-index: 2; position: relative;">
          <div style={`width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.875rem; transition: all 0.3s ease;`} class="step-circle">{step}</div>
          <span style="font-size: 0.75rem; font-weight: 600; color: var(--text-light);">{step === 1 ? 'Service' : step === 2 ? 'Contact' : 'Location'}</span>
        </div>
      ))}
    </div>
    <div style="text-align: center; margin-top: 0.75rem; font-size: 0.875rem; color: var(--text-light);">
      Step <span class="current-step-num">1</span> of 3
    </div>
  </div>

  <form action="https://script.google.com/macros/s/AKfycbzicY329SPUrcrn4x3wIQnI8Zz8iXCBdqWPB36IHKveKs-mIgiGw591V2F-tTjTWjcQ/exec" method="POST" id={`msf-${source}`}>
    <input type="hidden" name="source" value={source} />
    <input type="hidden" name="selected_service" id={`selected-service-${source}`} value="" />

    <!-- Step 1: Select Service -->
    <div class="form-step step-1" style="display: block;">
      <h3 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--secondary); text-align: center;">What service do you need?</h3>
      <p style="color: var(--text-light); text-align: center; margin-bottom: 1.5rem; font-size: 0.9375rem;">Select the drylining service you require.</p>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 0.75rem;">
        {services.map(s => (
          <button type="button" class="service-card" data-value={s.title} style="background: var(--white); border: 2px solid var(--border); border-radius: var(--radius); padding: 1.25rem 0.75rem; cursor: pointer; transition: all 0.2s ease; display: flex; flex-direction: column; align-items: center; gap: 0.75rem; text-align: center;"
            onclick={`this.closest('.multi-step-form').querySelector('#selected-service-${source}').value = '${s.title}'; this.closest('.multi-step-form').dispatchEvent(new CustomEvent('service-selected', {detail: '${s.title}'}));`}
          >
            <div style="color: var(--primary);">{typeof s.icon === 'string' ? <span set:html={s.icon} /> : null}</div>
            <span style="font-weight: 600; font-size: 0.875rem; color: var(--secondary);">{s.title}</span>
          </button>
        ))}
      </div>
    </div>

    <!-- Step 2: Contact Info -->
    <div class="form-step step-2" style="display: none;">
      <h3 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--secondary); text-align: center;">Your Contact Details</h3>
      <p style="color: var(--text-light); text-align: center; margin-bottom: 1.5rem; font-size: 0.9375rem;">Tell us how to reach you.</p>
      <div style="display: flex; flex-direction: column; gap: 1rem;">
        <div>
          <label style="display: block; font-weight: 600; margin-bottom: 0.375rem; font-size: 0.9375rem;">Name <span style="color: var(--primary);">*</span></label>
          <input type="text" name="name" required placeholder="Your full name" style="width: 100%; padding: 0.875rem 1rem; border: 1px solid var(--border); border-radius: var(--radius); font-size: 0.9375rem; font-family: inherit;" />
        </div>
        <div>
          <label style="display: block; font-weight: 600; margin-bottom: 0.375rem; font-size: 0.9375rem;">Phone <span style="color: var(--primary);">*</span></label>
          <input type="tel" name="phone" required placeholder="Your phone number" style="width: 100%; padding: 0.875rem 1rem; border: 1px solid var(--border); border-radius: var(--radius); font-size: 0.9375rem; font-family: inherit;" />
        </div>
        <div>
          <label style="display: block; font-weight: 600; margin-bottom: 0.375rem; font-size: 0.9375rem;">Email</label>
          <input type="email" name="email" placeholder="Your email address" style="width: 100%; padding: 0.875rem 1rem; border: 1px solid var(--border); border-radius: var(--radius); font-size: 0.9375rem; font-family: inherit;" />
        </div>
        <div>
          <label style="display: block; font-weight: 600; margin-bottom: 0.375rem; font-size: 0.9375rem;">Project Details</label>
          <textarea name="details" rows="3" placeholder="Briefly describe your project..." style="width: 100%; padding: 0.875rem 1rem; border: 1px solid var(--border); border-radius: var(--radius); font-size: 0.9375rem; font-family: inherit; resize: vertical;"></textarea>
        </div>
      </div>
      <div style="display: flex; gap: 0.75rem; margin-top: 1.5rem;">
        <button type="button" class="btn-back" style="flex: 1; padding: 0.875rem; background: var(--accent); color: var(--text); border: none; border-radius: var(--radius); font-weight: 600; cursor: pointer; transition: background 0.2s;">← Back</button>
        <button type="button" class="btn-next" style="flex: 2; padding: 0.875rem; background: var(--primary); color: var(--white); border: none; border-radius: var(--radius); font-weight: 600; cursor: pointer; transition: background 0.2s;">Next: Location →</button>
      </div>
    </div>

    <!-- Step 3: Location -->
    <div class="form-step step-3" style="display: none;">
      <h3 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--secondary); text-align: center;">Project Location</h3>
      <p style="color: var(--text-light); text-align: center; margin-bottom: 1.5rem; font-size: 0.9375rem;">Where is the project located?</p>
      <div style="display: flex; flex-direction: column; gap: 1rem;">
        <div>
          <label style="display: block; font-weight: 600; margin-bottom: 0.375rem; font-size: 0.9375rem;">Postcode <span style="color: var(--primary);">*</span></label>
          <input type="text" name="postcode" required placeholder="e.g. EH1 1AA" style="width: 100%; padding: 0.875rem 1rem; border: 1px solid var(--border); border-radius: var(--radius); font-size: 0.9375rem; font-family: inherit; text-transform: uppercase;" />
        </div>
        <div>
          <label style="display: block; font-weight: 600; margin-bottom: 0.375rem; font-size: 0.9375rem;">Address</label>
          <input type="text" name="address" placeholder="Street address" style="width: 100%; padding: 0.875rem 1rem; border: 1px solid var(--border); border-radius: var(--radius); font-size: 0.9375rem; font-family: inherit;" />
        </div>
        <div>
          <label style="display: block; font-weight: 600; margin-bottom: 0.375rem; font-size: 0.9375rem;">Preferred Timing</label>
          <select name="timing" style="width: 100%; padding: 0.875rem 1rem; border: 1px solid var(--border); border-radius: var(--radius); font-size: 0.9375rem; font-family: inherit; background: var(--white); color: var(--text);">
            <option value="" disabled selected>When do you need the work done?</option>
            <option>As soon as possible</option>
            <option>Within 2 weeks</option>
            <option>Within 1 month</option>
            <option>Flexible / Not urgent</option>
          </select>
        </div>
      </div>
      <div style="display: flex; gap: 0.75rem; margin-top: 1.5rem;">
        <button type="button" class="btn-back" style="flex: 1; padding: 0.875rem; background: var(--accent); color: var(--text); border: none; border-radius: var(--radius); font-weight: 600; cursor: pointer; transition: background 0.2s;">← Back</button>
        <button type="submit" class="btn-submit" style="flex: 2; padding: 0.875rem; background: var(--primary); color: var(--white); border: none; border-radius: var(--radius); font-weight: 600; cursor: pointer; transition: background 0.2s;">Submit Quote Request</button>
      </div>
    </div>

    <!-- Success Message -->
    <div class="form-step step-success" style="display: none; text-align: center; padding: 2rem 0;">
      <div style="font-size: 4rem; margin-bottom: 1rem;">✅</div>
      <h3 style="font-size: 1.5rem; font-weight: 700; color: var(--secondary); margin-bottom: 0.75rem;">Quote Request Sent!</h3>
      <p style="color: var(--text-light); margin-bottom: 1.5rem;">Thank you! We will be in touch within 24 hours.</p>
      <a href="/" class="btn btn-primary">Back to Home</a>
    </div>
  </form>

  <div class="form-error" style="display: none; padding: 1rem; background: #fee2e2; color: #b91c1c; border: 1px solid #fecaca; border-radius: var(--radius); margin-top: 1rem; font-size: 0.9375rem; text-align: center;">
    Something went wrong. Please call us on <a href="tel:0131XXXXXXX" style="color: var(--primary); text-decoration: underline;">0131 XXX XXXX</a> or try again.
  </div>
</div>

<style>
  .multi-step-form .service-card:hover {
    border-color: var(--primary) !important;
    background: var(--primary-light) !important;
  }
  .multi-step-form .service-card.selected {
    border-color: var(--primary) !important;
    background: var(--primary-light) !important;
    box-shadow: 0 0 0 3px rgba(196,30,58,0.2);
  }
  .multi-step-form .progress-step .step-circle {
    background: var(--white);
    border: 2px solid var(--border);
    color: var(--text-light);
  }
  .multi-step-form .progress-step.active .step-circle {
    background: var(--primary);
    border-color: var(--primary);
    color: var(--white);
  }
  .multi-step-form .progress-step.completed .step-circle {
    background: var(--primary);
    border-color: var(--primary);
    color: var(--white);
  }
  .btn-next:hover, .btn-submit:hover { background: var(--primary-dark) !important; }
  .btn-back:hover { background: #e5e5e5 !important; }
</style>

<script define:vars={{ source }}>
(function() {
  var form = document.getElementById('msf-' + source);
  if (!form) return;
  var container = form.closest('.multi-step-form');
  var steps = [1, 2, 3];
  var currentStep = 1;
  var selectedService = '';
  var selectedServiceInput = container.querySelector('[id^="selected-service-"]');

  function updateProgress(step) {
    currentStep = step;
    container.querySelector('.current-step-num').textContent = step;
    var fillPercent = step === 1 ? 0 : step === 2 ? 50 : 100;
    container.querySelector('.progress-line-fill').style.width = fillPercent + '%';
    
    steps.forEach(function(s) {
      var el = container.querySelector('.progress-step-' + s);
      el.classList.remove('active', 'completed');
      if (s === step) el.classList.add('active');
      else if (s < step) el.classList.add('completed');
    });
  }

  function showStep(n) {
    container.querySelectorAll('.form-step').forEach(function(el) { el.style.display = 'none'; });
    container.querySelector('.step-' + n).style.display = 'block';
    updateProgress(n);
  }

  // Service card selection
  container.querySelectorAll('.service-card').forEach(function(card) {
    card.addEventListener('click', function() {
      container.querySelectorAll('.service-card').forEach(function(c) { c.classList.remove('selected'); });
      card.classList.add('selected');
      selectedService = card.dataset.value;
      if (selectedServiceInput) selectedServiceInput.value = selectedService;
      setTimeout(function() { showStep(2); }, 200);
    });
  });

  // Navigation buttons
  container.querySelectorAll('.btn-next').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var stepEl = btn.closest('.form-step');
      var required = stepEl.querySelectorAll('[required]');
      var valid = true;
      required.forEach(function(field) {
        if (!field.value.trim()) {
          field.style.borderColor = 'var(--primary)';
          valid = false;
        } else {
          field.style.borderColor = 'var(--border)';
        }
      });
      if (valid) showStep(currentStep + 1);
    });
  });

  container.querySelectorAll('.btn-back').forEach(function(btn) {
    btn.addEventListener('click', function() {
      showStep(currentStep - 1);
    });
  });

  // Form submission
  form.addEventListener('submit', function(e) {
    e.preventDefault();
    var submitBtn = container.querySelector('.btn-submit');
    var errorDiv = container.querySelector('.form-error');
    if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Sending...'; }
    if (errorDiv) errorDiv.style.display = 'none';

    var data = new FormData(form);
    var payload = {};
    data.forEach(function(v, k) { payload[k] = v; });
    payload.sheet = 'Edinburgh';

    fetch(form.action, {
      method: 'POST',
      body: JSON.stringify(payload),
      headers: { 'Content-Type': 'application/json' }
    }).then(function(r) {
      if (r.ok || r.status === 0) {
        container.querySelectorAll('.form-step').forEach(function(el) { el.style.display = 'none'; });
        container.querySelector('.step-success').style.display = 'block';
        container.querySelector('.form-progress').style.display = 'none';
        form.reset();
      } else {
        throw new Error('Status ' + r.status);
      }
    }).catch(function(err) {
      if (errorDiv) errorDiv.style.display = 'block';
    }).finally(function() {
      if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Submit Quote Request'; }
    });
  });

  // Reset border on input
  container.querySelectorAll('input, textarea, select').forEach(function(field) {
    field.addEventListener('input', function() { field.style.borderColor = 'var(--border)'; });
  });
})();
</script>
